#!/usr/bin/env bash
# serve — turbofit's model launcher + Hermes-Agent config manager
# Part of the turbofit skill: github.com/SouthpawIN/turbofit

set -euo pipefail

# Paths
TURBOFIT_ROOT="${TURBOFIT_ROOT:-${HOME}/.local/share/turbofit}"
CATALOG="${HOME}/.config/turbofit/models.yaml"
HERMES_CONFIG="${HOME}/.hermes/config.yaml"
LLAMA_CPP_SRC="${HOME}/.local/src/llama.cpp"
LLAMA_CPP_PREFIX="${HOME}/.local"

mkdir -p "${TURBOFIT_ROOT}"/{logs,pid,port,strings} "${HOME}/.config/turbofit"

# ---- llama.cpp management ----

ensure_llama_cpp() {
    if ! command -v llama-server >/dev/null 2>&1; then
        echo "llama-server not found. Installing llama.cpp..."
        install_llama_cpp
    fi
}

install_llama_cpp() {
    mkdir -p "${LLAMA_CPP_SRC%/*}"
    if [ ! -d "${LLAMA_CPP_SRC}/.git" ]; then
        echo "Cloning llama.cpp..."
        git clone https://github.com/ggerganov/llama.cpp.git "${LLAMA_CPP_SRC}"
    fi
    cd "${LLAMA_CPP_SRC}"
    git pull --rebase --autostash 2>/dev/null || git pull --rebase
    cmake -B build -DCMAKE_BUILD_TYPE=Release -DGGML_CUDA=ON \
        -DCMAKE_INSTALL_PREFIX="${LLAMA_CPP_PREFIX}"
    cmake --build build --config Release -j"$(nproc)"
    cmake --install build
    export PATH="${LLAMA_CPP_PREFIX}/bin:${PATH}"
    echo "✓ llama.cpp installed to ${LLAMA_CPP_PREFIX}/bin/llama-server"
}

update_llama_cpp() {
    if [ ! -d "${LLAMA_CPP_SRC}/.git" ]; then
        install_llama_cpp
        return
    fi
    echo "Updating llama.cpp..."
    cd "${LLAMA_CPP_SRC}"
    git fetch origin
    if ! git pull --rebase --autostash 2>/dev/null; then
        git pull --rebase
    fi
    cmake --build build --config Release -j"$(nproc)"
    cmake --install build
    echo "✓ llama.cpp updated"
}

check_llama_cpp() {
    local binary_version
    binary_version=$(llama-server --version 2>/dev/null | head -1 || echo "not in PATH")
    echo "Binary:  ${binary_version}"
    if [ -d "${LLAMA_CPP_SRC}/.git" ]; then
        local current remote
        current=$(cd "${LLAMA_CPP_SRC}" && git rev-parse --short HEAD)
        remote=$(cd "${LLAMA_CPP_SRC}" && git rev-parse --short origin/master 2>/dev/null) || remote="unknown"
        echo "Local:   ${current}"
        echo "Remote:  ${remote}"
        if [ "${current}" != "${remote}" ]; then
            echo "Status:  OUT OF DATE — run 'serve update'"
        else
            echo "Status:  up to date"
        fi
    else
        echo "Source:  not cloned — run 'serve install'"
    fi
}

# ---- llmfit integration ----

check_fit() {
    local model_ref="$1"
    local requested_ctx="${2:-65536}"
    llmfit plan "${model_ref}" --context "${requested_ctx}" --json || true
}

# ---- Launch string generation ----

generate_string() {
    local model_path="$1"
    local ctx="${2:-65536}"
    local port="${3:-8080}"
    local host="${4:-127.0.0.1}"
    local ngl="${5:-99}"
    local threads="${6:-$(nproc)}"

    ctx=$(( ctx < 65536 ? 65536 : ctx ))

    cat <<EOF
llama-server \\
  -m "${model_path}" \\
  --host ${host} --port ${port} \\
  -ngl ${ngl} -fa on \\
  -c ${ctx} \\
  --jinja \\
  -t ${threads}
EOF
}

# ---- Alias lookup ----

alias_info() {
    local alias="$1"
    python3 - "$alias" <<'PYEOF'
import sys, os, yaml
alias = sys.argv[1]
catalog = os.path.expanduser("~/.config/turbofit/models.yaml")
if not os.path.exists(catalog):
    print("", file=sys.stderr)
    sys.exit(1)
with open(catalog) as f:
    cfg = yaml.safe_load(f) or {}
m = cfg.get("models", {}).get(alias)
if not m:
    print("", file=sys.stderr)
    sys.exit(1)
print(m.get("path", ""), m.get("port", 8080), m.get("ctx", 65536))
PYEOF
}

alias_exists() {
    local alias="$1"
    [ -n "$(alias_info "$alias" 2>/dev/null)" ]
}

# ---- Server lifecycle ----

launch_server() {
    local alias="$1"
    local info path port ctx
    info=$(alias_info "$alias")
    path=$(echo "$info" | awk '{print $1}')
    port=$(echo "$info" | awk '{print $2}')
    ctx=$(echo "$info" | awk '{print $3}')

    if [ -z "$path" ]; then
        echo "✗ Unknown alias: $alias"
        echo "  Register with: name $alias <path-to-gguf>"
        return 1
    fi

    # Kill any existing process on this port
    if [ -f "${TURBOFIT_ROOT}/pid/${alias}" ]; then
        local old_pid
        old_pid=$(cat "${TURBOFIT_ROOT}/pid/${alias}")
        if kill -0 "${old_pid}" 2>/dev/null; then
            echo "Stopping existing ${alias} (pid ${old_pid})..."
            kill "${old_pid}" 2>/dev/null || true
            sleep 1
            kill -9 "${old_pid}" 2>/dev/null || true
        fi
        rm -f "${TURBOFIT_ROOT}/pid/${alias}" "${TURBOFIT_ROOT}/port/${alias}"
    fi

    # Write launch string
    local cmd_file="${TURBOFIT_ROOT}/strings/${alias}.sh"
    generate_string "${path}" "${ctx}" "${port}" > "${cmd_file}"
    chmod +x "${cmd_file}"

    # Launch detached
    local log_file="${TURBOFIT_ROOT}/logs/${alias}.log"
    nohup bash -c "$(cat "${cmd_file}")" > "${log_file}" 2>&1 &
    disown
    local pid=$!
    echo "${pid}" > "${TURBOFIT_ROOT}/pid/${alias}"
    echo "${port}" > "${TURBOFIT_ROOT}/port/${alias}"

    # Wait for ready (up to 120s)
    echo "Launching ${alias} (pid ${pid}) on :${port}..."
    for i in $(seq 1 120); do
        if curl -sf "http://127.0.0.1:${port}/health" >/dev/null 2>&1; then
            echo ""
            echo "✓ ${alias} ready"
            echo ""
            echo "  Port:  :${port}"
            echo "  PID:   ${pid}"
            echo "  Logs:  ${log_file}"
            echo "  Stop:  serve stop ${alias}"
            return 0
        fi
        if ! kill -0 "${pid}" 2>/dev/null; then
            echo ""
            echo "✗ ${alias} died during startup. Tail of log:"
            tail -20 "${log_file}" 2>/dev/null || true
            return 1
        fi
        sleep 1
    done
    echo ""
    echo "✗ ${alias} did not become healthy within 120s"
    echo "  Logs: ${log_file}"
    return 1
}

stop_server() {
    local alias="$1"
    if [ -f "${TURBOFIT_ROOT}/pid/${alias}" ]; then
        local pid
        pid=$(cat "${TURBOFIT_ROOT}/pid/${alias}")
        if kill -0 "${pid}" 2>/dev/null; then
            kill "${pid}" 2>/dev/null || true
            sleep 1
            kill -9 "${pid}" 2>/dev/null || true
        fi
        rm -f "${TURBOFIT_ROOT}/pid/${alias}" "${TURBOFIT_ROOT}/port/${alias}"
        echo "✓ Stopped ${alias}"
    else
        echo "No running server for: ${alias}"
    fi
}

list_running() {
    echo "Running servers:"
    if [ -d "${TURBOFIT_ROOT}/pid" ]; then
        for pid_file in "${TURBOFIT_ROOT}/pid"/*; do
            [ -f "${pid_file}" ] || continue
            local alias pid port
            alias=$(basename "${pid_file}")
            pid=$(cat "${pid_file}")
            port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo "?")
            if kill -0 "${pid}" 2>/dev/null; then
                echo "  ${alias}: pid ${pid}, :${port}"
            else
                rm -f "${pid_file}"
            fi
        done
    fi
    if [ -d "${TURBOFIT_ROOT}/port" ]; then
        echo ""
        echo "Ports:"
        for port_file in "${TURBOFIT_ROOT}/port"/*; do
            [ -f "${port_file}" ] || continue
            local alias port
            alias=$(basename "${port_file}")
            port=$(cat "${port_file}")
            echo "  :${port} → ${alias}"
        done
    fi
}

# ---- Hermes-Agent config ----

set_hermes_main() {
    local model_name="$1"
    local port="$2"
    local base_url="http://127.0.0.1:${port}/v1"

    python3 - <<PYEOF
import yaml, os
cfg_path = "${HERMES_CONFIG}"
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("model", {})
cfg["model"]["default"] = "${model_name}"
cfg["model"]["base_url"] = "${base_url}"
cfg["model"]["api_key"] = "not-needed"
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Hermes-Agent main: ${model_name} @ ${base_url}"
}

set_hermes_aux() {
    local model_name="$1"
    local port="$2"
    local base_url="http://127.0.0.1:${port}/v1"
    local tasks=(vision web_extract compression session_search skills_hub approval mcp title_generation curator)

    python3 - <<PYEOF
import yaml, os
cfg_path = "${HERMES_CONFIG}"
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("auxiliary", {})
tasks = ${tasks[@]@Q}
for task in tasks:
    cfg["auxiliary"].setdefault(task, {})
    cfg["auxiliary"][task]["provider"] = "custom:local"
    cfg["auxiliary"][task]["base_url"] = "${base_url}"
    cfg["auxiliary"][task]["api_key"] = "not-needed"
    cfg["auxiliary"][task]["model"] = "${model_name}"
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Hermes-Agent aux: ${model_name} @ ${base_url} (${#tasks[@]} tasks)"
}

# ---- Catalog ----

next_port() {
    local used=()
    [ -f "${CATALOG}" ] && used+=($(grep -oE "port: [0-9]+" "${CATALOG}" 2>/dev/null | grep -oE "[0-9]+" || true))
    local port=8080
    while printf "%s\\n" "${used[@]}" | grep -qx "${port}" 2>/dev/null; do
        port=$((port + 1))
    done
    echo "${port}"
}

register_alias() {
    local alias="$1"
    local path="$2"
    if [ -z "${alias}" ] || [ -z "${path}" ]; then
        echo "Usage: name <alias> <path-to-gguf-or-hf-repo>"
        return 1
    fi
    local port
    port=$(next_port)
    python3 - <<PYEOF
import yaml, os
cfg_path = "${CATALOG}"
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("models", {})
cfg["models"]["${alias}"] = {"path": "${path}", "port": ${port}}
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Registered '${alias}' → ${path} on :${port}"
}

list_catalog() {
    if [ ! -f "${CATALOG}" ]; then
        echo "Catalog empty. Use 'name <alias> <path>' to register a model."
        return
    fi
    python3 - <<PYEOF
import yaml
with open("${CATALOG}") as f:
    cfg = yaml.safe_load(f) or {}
models = cfg.get("models", {})
if not models:
    print("Catalog empty.")
else:
    print(f"{'Alias':<25} {'Port':<8} Path")
    print("-" * 80)
    for alias, info in sorted(models.items()):
        print(f"{alias:<25} {info.get('port', '?'):<8} {info.get('path', '?')}")
PYEOF
}

# ---- High-level: launch + set as main/aux + start hermes/herm ----

serve_main() {
    local alias="$1"
    local use_gateway="${USE_GATEWAY:-0}"
    launch_server "${alias}" || return 1
    local port
    port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
    set_hermes_main "${alias}" "${port}"
    if [ "${use_gateway}" = "1" ]; then
        echo "Starting hermes gateway..."
        exec hermes gateway run
    else
        echo "Starting hermes TUI..."
        exec hermes --tui
    fi
}

serve_aux() {
    local alias="$1"
    local use_gateway="${USE_GATEWAY:-0}"
    launch_server "${alias}" || return 1
    local port
    port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
    set_hermes_aux "${alias}" "${port}"
    if [ "${use_gateway}" = "1" ]; then
        echo "Starting hermes gateway (aux model)..."
        exec hermes gateway run
    else
        echo "Starting hermes TUI (aux model)..."
        exec hermes --tui
    fi
}

# serve herm <alias> — launch + set main + start herm TUI + hermes
# serve herm aux <alias> — launch + set aux + start herm TUI + hermes
serve_herm() {
    local first="${1:-}"
    local alias
    if [ "${first}" = "aux" ]; then
        alias="${2:-}"
        [ -z "${alias}" ] && { echo "Usage: serve herm aux <alias>"; return 1; }
        launch_server "${alias}" || return 1
        local port
        port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
        set_hermes_aux "${alias}" "${port}"
    else
        alias="${first}"
        [ -z "${alias}" ] && { echo "Usage: serve herm <alias>"; return 1; }
        launch_server "${alias}" || return 1
        local port
        port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
        set_hermes_main "${alias}" "${port}"
    fi

    # Start herm TUI in background (if installed), then hermes in foreground
    if command -v herm >/dev/null 2>&1; then
        echo "Starting herm TUI..."
        nohup herm >/dev/null 2>&1 &
        disown
        sleep 1
    else
        echo "(herm TUI not in PATH — skipping)"
    fi

    echo "Starting hermes TUI..."
    exec hermes --tui
}

# ---- Command dispatcher ----

usage() {
    cat <<EOF
turbofit serve — llama.cpp launcher + Hermes-Agent config

USAGE:
  serve install                                 Install llama.cpp from source
  serve update                                  Update llama.cpp to latest master
  serve check                                   Show binary version + commit status
  serve fit <model> [ctx]                       Run llmfit fit check

  serve register <alias> <path>                 Register a model alias
  serve catalog                                 Show registered aliases

  serve <alias>                                 Launch the server (detached, shows port + logs)
  serve string <alias>                          Print launch string (no launch)
  serve stop <alias>                            Stop a running server
  serve list                                    List running servers

  serve main <alias>                            Launch + set as Hermes main + start hermes
  serve aux <alias>                             Launch + set as Hermes aux + start hermes
  serve herm <alias>                            Launch + set main + start herm TUI + hermes
  serve herm aux <alias>                        Launch + set aux + start herm TUI + hermes

Append --gateway to 'serve main' or 'serve aux' to start the hermes gateway
instead of the TUI.

SHELL ALIASES (installed to ~/.bashrc):
  name <alias> <path>                           Register a model alias
  serve <alias>                                 Launch + show port/logs
  serve main <alias>                            Launch + set main + start hermes TUI
  serve aux <alias>                             Launch + set aux + start hermes TUI
  serve herm <alias>                            Launch + main + herm TUI + hermes
  serve herm aux <alias>                        Launch + aux + herm TUI + hermes
EOF
}

# Detect --gateway flag anywhere in args
gateway_flag=0
new_args=()
for a in "$@"; do
    if [ "$a" = "--gateway" ] || [ "$a" = "-gateway" ]; then
        gateway_flag=1
    else
        new_args+=("$a")
    fi
done
if [ "${#new_args[@]}" -gt 0 ]; then
    set -- "${new_args[@]}"
else
    set --
fi
export USE_GATEWAY="${gateway_flag}"

cmd="${1:-help}"
shift || true

case "${cmd}" in
    install)        install_llama_cpp ;;
    update)         update_llama_cpp ;;
    check)          check_llama_cpp ;;
    fit)            check_fit "$@" ;;
    string)         if [ -z "${1:-}" ]; then
                        echo "Usage: serve string <alias>"
                        exit 1
                    fi
                    info=$(alias_info "$1" 2>/dev/null) || { echo "Unknown alias: $1"; exit 1; }
                    path=$(echo "$info" | awk '{print $1}')
                    port=$(echo "$info" | awk '{print $2}')
                    ctx=$(echo "$info" | awk '{print $3}')
                    generate_string "$path" "$ctx" "$port"
                    ;;
    stop)           stop_server "${1:-}" ;;
    list|ls|ps)     list_running ;;
    catalog)        list_catalog ;;
    register|name)  register_alias "${1:-}" "${2:-}" ;;
    main)           serve_main "${1:-}" ;;
    aux)            serve_aux "${1:-}" ;;
    herm)           shift; serve_herm "$@" ;;
    help|*)         # If first arg matches a registered alias, launch it
                    if alias_exists "${cmd}" 2>/dev/null; then
                        launch_server "${cmd}"
                    else
                        usage
                    fi
                    ;;
esac