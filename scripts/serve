#!/usr/bin/env bash
# serve — turbofit model launcher + Hermes-Agent config manager
# Part of the turbofit skill: github.com/SouthpawIN/turbofit
# v4.0.0: multi-launcher (llama.cpp / Ollama / vllm / SGlang), hardware-fit check,
# NVIDIA NIM API curated list, Desktop/Dashboard UI support.

set -euo pipefail

TURBOFIT_ROOT="${TURBOFIT_ROOT:-${HOME}/.local/share/turbofit}"
CATALOG="${HOME}/.config/turbofit/models.yaml"
HERMES_CONFIG="${HOME}/.hermes/config.yaml"
NVIDIA_API_BASE="https://integrate.api.nvidia.com/v1"

mkdir -p "${TURBOFIT_ROOT}"/{logs,pid,port,strings,launchers} "${HOME}/.config/turbofit"

# ---- Launcher registry (extensible — add more here) ----
# Each entry: name | install_cmd | launch_template | base_url_default | api_style
declare -A LAUNCHER_NAME=(
    [llama-cpp]="llama.cpp (ggerganov)"
    [ollama]="Ollama"
    [vllm]="vLLM"
    [sglang]="SGlang"
)

declare -A LAUNCHER_INSTALL=(
    [llama-cpp]="llama.cpp:git_clone"
    [ollama]="ollama:curl_install"
    [vllm]="vllm:pip_install"
    [sglang]="sglang:pip_install"
)

# launch_template uses these variables:
#   $PORT  - port to bind
#   $HOST  - host to bind
#   $MODEL_PATH or $HF_REPO - what to load
#   $CTX   - context size
#   $NGL   - GPU layers
declare -A LAUNCHER_TEMPLATE=(
    [llama-cpp]='llama-server -m "$MODEL_PATH" --host "$HOST" --port "$PORT" -ngl "$NGL" -fa on -c "$CTX" --jinja'
    [ollama]='OLLAMA_HOST="$HOST:$PORT" ollama serve'
    [vllm]='vllm serve "$MODEL_PATH" --host "$HOST" --port "$PORT" --max-model-len "$CTX" --gpu-memory-utilization 0.9'
    [sglang]='python -m sglang.launch_server --model-path "$MODEL_PATH" --host "$HOST" --port "$PORT" --context-length "$CTX" --tp 1'
)

declare -A LAUNCHER_URL=(
    [llama-cpp]='http://$HOST:$PORT/v1'
    [ollama]='http://$HOST:$PORT/v1'
    [vllm]='http://$HOST:$PORT/v1'
    [sglang]='http://$HOST:$PORT/v1'
)

# ---- NVIDIA NIM curated API list (verified 2026-06-22) ----
# Rank order matters — serve rank <alias> picks top available
NVIDIA_NIM_FILE="${TURBOFIT_ROOT}/nvidia-nim-curated.yaml"

