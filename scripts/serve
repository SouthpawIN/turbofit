# ---- llama.cpp management ----

ensure_llama_cpp() {
    if ! command -v llama-server >/dev/null 2>&1; then
        install_launcher llama-cpp
    fi
}

install_launcher() {
    local which="$1"
    case "${which}" in
        llama-cpp)
            local src="${HOME}/.local/src/llama.cpp"
            local prefix="${HOME}/.local"
            mkdir -p "${src%/*}"
            if [ ! -d "${src}/.git" ]; then
                echo "Cloning llama.cpp..."
                git clone https://github.com/ggerganov/llama.cpp.git "${src}"
            fi
            cd "${src}"
            git pull --rebase --autostash 2>/dev/null || git pull --rebase
            cmake -B build -DCMAKE_BUILD_TYPE=Release -DGGML_CUDA=ON \
                -DCMAKE_INSTALL_PREFIX="${prefix}"
            cmake --build build --config Release -j"$(nproc)"
            cmake --install build
            export PATH="${prefix}/bin:${PATH}"
            echo "✓ llama.cpp installed"
            ;;
        ollama)
            echo "Installing Ollama..."
            curl -fsSL https://ollama.com/install.sh | sh
            echo "✓ Ollama installed"
            ;;
        vllm)
            echo "Installing vllm (pip)..."
            pip install -U vllm
            echo "✓ vllm installed"
            ;;
        sglang)
            echo "Installing SGlang (pip)..."
            pip install -U "sglang[all]"
            echo "✓ SGlang installed"
            ;;
        *)
            echo "✗ Unknown launcher: ${which}"
            echo "  Supported: ${!LAUNCHER_NAME[*]}"
            return 1
            ;;
    esac
}

update_llama_cpp() {
    local src="${HOME}/.local/src/llama.cpp"
    if [ ! -d "${src}/.git" ]; then
        install_launcher llama-cpp
        return
    fi
    echo "Updating llama.cpp..."
    cd "${src}"
    git fetch origin
    git pull --rebase --autostash 2>/dev/null || git pull --rebase
    cmake --build build --config Release -j"$(nproc)"
    cmake --install build
    echo "✓ llama.cpp updated"
}

update_all_launchers() {
    local target="${1:-all}"
    if [ "${target}" = "all" ]; then
        for l in "${!LAUNCHER_NAME[@]}"; do
            echo "--- Updating ${l} ---"
            case "${l}" in
                llama-cpp) update_llama_cpp ;;
                ollama)    install_launcher ollama ;;
                vllm)      pip install -U vllm ;;
                sglang)    pip install -U "sglang[all]" ;;
            esac
        done
    else
        case "${target}" in
            llama-cpp) update_llama_cpp ;;
            ollama)    install_launcher ollama ;;
            vllm)      pip install -U vllm ;;
            sglang)    pip install -U "sglang[all]" ;;
            *) echo "Unknown launcher: ${target}"; return 1 ;;
        esac
    fi
}

check_llama_cpp() {
    local binary_version
    binary_version=$(llama-server --version 2>/dev/null | head -1 || echo "not in PATH")
    echo "llama.cpp: ${binary_version}"
    local src="${HOME}/.local/src/llama.cpp"
    if [ -d "${src}/.git" ]; then
        local current remote
        current=$(cd "${src}" && git rev-parse --short HEAD)
        remote=$(cd "${src}" && git rev-parse --short origin/master 2>/dev/null) || remote="unknown"
        echo "  local commit:  ${current}"
        echo "  remote commit: ${remote}"
        [ "${current}" != "${remote}" ] && echo "  status: OUT OF DATE — run 'serve update'" || echo "  status: up to date"
    fi
    echo ""
    echo "Other launchers:"
    for l in ollama vllm sglang; do
        local ver="missing"
        command -v "${l}" >/dev/null 2>&1 && ver="$(${l} --version 2>&1 | head -1 || echo 'present')"
        printf "  %-10s %s\n" "${l}:" "${ver}"
    done
}

# ---- Hardware fit check ----

check_fit() {
    local model_ref="$1"
    local requested_ctx="${2:-65536}"
    if ! command -v llmfit >/dev/null 2>&1; then
        echo "llmfit not installed. Run: pip install -U llmfit  (or brew install AlexsJones/llmfit/llmfit)"
        return 1
    fi
    llmfit plan "${model_ref}" --context "${requested_ctx}" --json
}

# ---- Alias lookup ----

alias_info() {
    local alias="$1"
    python3 - "$alias" <<'PYEOF'
import sys, os, yaml
alias = sys.argv[1]
catalog = os.path.expanduser("~/.config/turbofit/models.yaml")
if not os.path.exists(catalog):
    print("", file=sys.stderr)
    sys.exit(1)
with open(catalog) as f:
    cfg = yaml.safe_load(f) or {}
m = cfg.get("models", {}).get(alias)
if not m:
    print("", file=sys.stderr)
    sys.exit(1)
# Format: launcher path port ctx
print(m.get("launcher", "llama-cpp"),
      m.get("path", ""),
      m.get("port", 8080),
      m.get("ctx", 65536))
PYEOF
}

alias_exists() {
    [ -n "$(alias_info "$1" 2>/dev/null)" ]
}

# ---- Generate launch string for a registered alias ----

generate_string() {
    local alias="$1"
    local info launcher path port ctx
    info=$(alias_info "${alias}")
    launcher=$(echo "${info}" | awk '{print $1}')
    path=$(echo "${info}" | awk '{print $2}')
    port=$(echo "${info}" | awk '{print $3}')
    ctx=$(echo "${info}" | awk '{print $4}')
    ctx=$(( ctx < 65536 ? 65536 : ctx ))

    local host="127.0.0.1"
    local ngl=99

    case "${launcher}" in
        llama-cpp)
            cat <<EOF
llama-server \\
  -m "${path}" \\
  --host ${host} --port ${port} \\
  -ngl ${ngl} -fa on \\
  -c ${ctx} \\
  --jinja \\
  -t $(nproc)
EOF
            ;;
        ollama)
            cat <<EOF
# Pull the model first (one-time)
ollama pull ${path}

# Launch Ollama server
OLLAMA_HOST="${host}:${port}" ollama serve
EOF
            ;;
        vllm)
            cat <<EOF
vllm serve ${path} \\
  --host ${host} \\
  --port ${port} \\
  --max-model-len ${ctx} \\
  --gpu-memory-utilization 0.9 \\
  --served-model-name ${alias}
EOF
            ;;
        sglang)
            cat <<EOF
python -m sglang.launch_server \\
  --model-path ${path} \\
  --host ${host} \\
  --port ${port} \\
  --context-length ${ctx} \\
  --served-model-name ${alias} \\
  --tp 1
EOF
            ;;
    esac
}

# ---- Server lifecycle ----

launch_server() {
    local alias="$1"
    local info launcher path port ctx
    info=$(alias_info "${alias}")
    launcher=$(echo "${info}" | awk '{print $1}')
    path=$(echo "${info}" | awk '{print $2}')
    port=$(echo "${info}" | awk '{print $3}')
    ctx=$(echo "${info}" | awk '{print $4}')

    if [ -z "${path}" ]; then
        echo "✗ Unknown alias: ${alias}"
        echo "  Register with: name ${alias} <path-or-hf-repo> [--launcher llama-cpp|ollama|vllm|sglang]"
        return 1
    fi

    # Kill any existing process on this port
    if [ -f "${TURBOFIT_ROOT}/pid/${alias}" ]; then
        local old_pid
        old_pid=$(cat "${TURBOFIT_ROOT}/pid/${alias}")
        if kill -0 "${old_pid}" 2>/dev/null; then
            echo "Stopping existing ${alias} (pid ${old_pid})..."
            kill "${old_pid}" 2>/dev/null || true
            sleep 1
            kill -9 "${old_pid}" 2>/dev/null || true
        fi
        rm -f "${TURBOFIT_ROOT}/pid/${alias}" "${TURBOFIT_ROOT}/port/${alias}"
    fi

    # Write launch string
    local cmd_file="${TURBOFIT_ROOT}/strings/${alias}.sh"
    generate_string "${alias}" > "${cmd_file}"
    chmod +x "${cmd_file}"

    # Launch detached (use the launcher-specific command)
    local log_file="${TURBOFIT_ROOT}/logs/${alias}.log"
    local host="127.0.0.1"
    local ngl=99
    ctx=$(( ctx < 65536 ? 65536 : ctx ))

    case "${launcher}" in
        llama-cpp)
            nohup llama-server -m "${path}" --host "${host}" --port "${port}" \
                -ngl "${ngl}" -fa on -c "${ctx}" --jinja -t "$(nproc)" \
                > "${log_file}" 2>&1 &
            ;;
        ollama)
            OLLAMA_HOST="${host}:${port}" nohup ollama serve > "${log_file}" 2>&1 &
            ;;
        vllm)
            nohup vllm serve "${path}" --host "${host}" --port "${port}" \
                --max-model-len "${ctx}" --gpu-memory-utilization 0.9 \
                --served-model-name "${alias}" > "${log_file}" 2>&1 &
            ;;
        sglang)
            nohup python -m sglang.launch_server --model-path "${path}" \
                --host "${host}" --port "${port}" --context-length "${ctx}" \
                --served-model-name "${alias}" --tp 1 > "${log_file}" 2>&1 &
            ;;
    esac

    disown
    local pid=$!
    echo "${pid}" > "${TURBOFIT_ROOT}/pid/${alias}"
    echo "${port}" > "${TURBOFIT_ROOT}/port/${alias}"

    echo "Launching ${alias} (pid ${pid}) via ${launcher} on :${port}..."
    for i in $(seq 1 120); do
        if curl -sf "http://127.0.0.1:${port}/health" >/dev/null 2>&1 || \
           curl -sf "http://127.0.0.1:${port}/v1/models" >/dev/null 2>&1; then
            echo ""
            echo "✓ ${alias} ready"
            echo ""
            echo "  Backend: ${launcher}"
            echo "  Port:   :${port}"
            echo "  PID:    ${pid}"
            echo "  Logs:   ${log_file}"
            echo "  Stop:   serve stop ${alias}"
            return 0
        fi
        if ! kill -0 "${pid}" 2>/dev/null; then
            echo ""
            echo "✗ ${alias} died during startup. Tail of log:"
            tail -20 "${log_file}" 2>/dev/null || true
            return 1
        fi
        sleep 1
    done
    echo ""
    echo "✗ ${alias} did not become healthy within 120s"
    echo "  Logs: ${log_file}"
    return 1
}

stop_server() {
    local alias="$1"
    if [ -f "${TURBOFIT_ROOT}/pid/${alias}" ]; then
        local pid
        pid=$(cat "${TURBOFIT_ROOT}/pid/${alias}")
        if kill -0 "${pid}" 2>/dev/null; then
            kill "${pid}" 2>/dev/null || true
            sleep 1
            kill -9 "${pid}" 2>/dev/null || true
        fi
        rm -f "${TURBOFIT_ROOT}/pid/${alias}" "${TURBOFIT_ROOT}/port/${alias}"
        echo "✓ Stopped ${alias}"
    else
        echo "No running server for: ${alias}"
    fi
}

list_running() {
    echo "Running servers:"
    if [ -d "${TURBOFIT_ROOT}/pid" ]; then
        for pid_file in "${TURBOFIT_ROOT}/pid"/*; do
            [ -f "${pid_file}" ] || continue
            local alias pid port
            alias=$(basename "${pid_file}")
            pid=$(cat "${pid_file}")
            port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo "?")
            if kill -0 "${pid}" 2>/dev/null; then
                echo "  ${alias}: pid ${pid}, :${port}"
            else
                rm -f "${pid_file}"
            fi
        done
    fi
}

# ---- Hermes-Agent config ----

set_hermes_main() {
    local model_name="$1"
    local base_url="$2"

    python3 - <<PYEOF
import yaml, os
cfg_path = "${HERMES_CONFIG}"
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("model", {})
cfg["model"]["default"] = "${model_name}"
cfg["model"]["base_url"] = "${base_url}"
cfg["model"]["api_key"] = "not-needed"
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Hermes main: ${model_name} @ ${base_url}"
}

set_hermes_aux() {
    local model_name="$1"
    local base_url="$2"
    local tasks=(vision web_extract compression session_search skills_hub approval mcp title_generation curator)

    python3 - <<PYEOF
import yaml, os
cfg_path = "${HERMES_CONFIG}"
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("auxiliary", {})
tasks = ${tasks[@]@Q}
for task in tasks:
    cfg["auxiliary"].setdefault(task, {})
    cfg["auxiliary"][task]["provider"] = "custom:local"
    cfg["auxiliary"][task]["base_url"] = "${base_url}"
    cfg["auxiliary"][task]["api_key"] = "not-needed"
    cfg["auxiliary"][task]["model"] = "${model_name}"
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Hermes aux: ${model_name} @ ${base_url} (${#tasks[@]} tasks)"
}

# ---- NVIDIA NIM API helpers ----

nvidia_nim_list() {
    [ -f "${NVIDIA_NIM_FILE}" ] || write_nvidia_nim_list
    python3 - <<'PYEOF'
import yaml
with open("/root/.local/share/turbofit/nvidia-nim-curated.yaml".replace("/root", __import__("os").path.expanduser("~"))) as f:
    cfg = yaml.safe_load(f)
print(f"Provider: {cfg['provider']}  base_url: {cfg['base_url']}")
print(f"{'Rank':<5} {'Model':<22} {'Vision':<7} {'$/in':<8} {'$/out':<8} API ID")
print("-" * 100)
for m in cfg['models']:
    vis = "👁 yes" if m['has_vision'] else "  no"
    print(f"{m['rank']:<5} {m['name']:<22} {vis:<7} ${m['price_input']:<7.2f} ${m['price_output']:<7.2f} {m['api_id']}")
PYEOF
}

nvidia_nim_use() {
    local rank_or_id="$1"
    local role="${2:-main}"
    [ -f "${NVIDIA_NIM_FILE}" ] || write_nvidia_nim_list

    python3 - "${rank_or_id}" "${role}" "${HERMES_CONFIG}" <<'PYEOF'
import sys, os, yaml
target, role, cfg_path = sys.argv[1], sys.argv[2], sys.argv[3]
with open(os.path.expanduser("~/.local/share/turbofit/nvidia-nim-curated.yaml")) as f:
    cfg = yaml.safe_load(f)
m = next((x for x in cfg['models'] if x['rank'] == int(target) or x['api_id'] == target), None)
if not m:
    print(f"Unknown rank/id: {target}")
    sys.exit(1)
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg2 = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg2.setdefault("model", {})
cfg2["model"]["default"] = m['api_id']
cfg2["model"]["base_url"] = "https://integrate.api.nvidia.com/v1"
cfg2["model"]["api_key"] = "${NVIDIA_API_KEY}"
cfg2["model"]["context_length"] = cfg.get("context_length", 1000000)
if role == "aux":
    cfg2.setdefault("auxiliary", {})
    for task in ("vision","web_extract","compression","session_search","skills_hub","approval","mcp","title_generation","curator"):
        cfg2["auxiliary"].setdefault(task, {})
        cfg2["auxiliary"][task]["provider"] = "openai"
        cfg2["auxiliary"][task]["base_url"] = "https://integrate.api.nvidia.com/v1"
        cfg2["auxiliary"][task]["api_key"] = "${NVIDIA_API_KEY}"
        cfg2["auxiliary"][task]["model"] = m['api_id']
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg2, f, default_flow_style=False, sort_keys=False)
print(f"✓ Hermes {role}: {m['name']} ({m['api_id']})")
PYEOF
}

# ---- Catalog ----

next_port() {
    local used=()
    [ -f "${CATALOG}" ] && used+=($(grep -oE "port: [0-9]+" "${CATALOG}" 2>/dev/null | grep -oE "[0-9]+" || true))
    local port=8080
    while printf "%s\\n" "${used[@]}" | grep -qx "${port}" 2>/dev/null; do
        port=$((port + 1))
    done
    echo "${port}"
}

register_alias() {
    local alias="$1"
    local path="$2"
    local launcher="llama-cpp"
    local port
    shift 2
    while [ $# -gt 0 ]; do
        case "$1" in
            --launcher) launcher="$2"; shift 2 ;;
            --port)     port="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ -z "${alias}" ] || [ -z "${path}" ]; then
        echo "Usage: name <alias> <path-or-hf-repo> [--launcher llama-cpp|ollama|vllm|sglang] [--port N]"
        return 1
    fi
    [ -z "${port:-}" ] && port=$(next_port)

    python3 - <<PYEOF
import yaml, os
cfg_path = "${CATALOG}"
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("models", {})
cfg["models"]["${alias}"] = {
    "launcher": "${launcher}",
    "path": "${path}",
    "port": ${port},
    "ctx": 65536,
}
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Registered '${alias}' → ${path} (launcher=${launcher}) on :${port}"
}

list_catalog() {
    if [ ! -f "${CATALOG}" ]; then
        echo "Catalog empty. Use 'name <alias> <path>' to register a model."
        return
    fi
    python3 - <<'PYEOF'
import yaml, os
catalog = os.path.expanduser("~/.config/turbofit/models.yaml")
with open(catalog) as f:
    cfg = yaml.safe_load(f) or {}
models = cfg.get("models", {})
if not models:
    print("Catalog empty.")
else:
    print(f"{'Alias':<25} {'Launcher':<12} {'Port':<8} Path")
    print("-" * 80)
    for alias, info in sorted(models.items()):
        print(f"{alias:<25} {info.get('launcher','llama-cpp'):<12} {info.get('port','?'):<8} {info.get('path','?')}")
PYEOF
}

# ---- High-level: launch + set as main/aux + start UI ----

start_ui() {
    local ui="${1:-tui}"   # tui|dashboard|gateway|desktop|herm|herm_main|herm_aux
    case "${ui}" in
        tui)       exec hermes --tui ;;
        dashboard) exec hermes dashboard ;;
        desktop)   exec hermes desktop ;;
        gateway)   exec hermes gateway run ;;
        herm)
            if command -v herm >/dev/null 2>&1; then
                nohup herm >/dev/null 2>&1 &
                disown
                sleep 1
            else
                echo "(herm TUI not in PATH — skipping)"
            fi
            exec hermes --tui
            ;;
        *)
            echo "Unknown UI: ${ui}"
            echo "  Supported: tui, dashboard, desktop, gateway, herm"
            return 1
            ;;
    esac
}

serve_main() {
    local alias="$1"
    local ui="${UI:-tui}"
    launch_server "${alias}" || return 1
    local port
    port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
    set_hermes_main "${alias}" "http://127.0.0.1:${port}/v1"
    start_ui "${ui}"
}

serve_aux() {
    local alias="$1"
    local ui="${UI:-tui}"
    launch_server "${alias}" || return 1
    local port
    port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
    set_hermes_aux "${alias}" "http://127.0.0.1:${port}/v1"
    start_ui "${ui}"
}

serve_herm() {
    local first="${1:-}"
    if [ "${first}" = "aux" ]; then
        shift
        UI="herm_aux" serve_aux "${1:-}"
    else
        UI="herm_main" serve_main "${first}"
    fi
}

# ---- Usage ----

usage() {
    cat <<EOF
turbofit serve — hardware-fit + launcher + Hermes config

INSTALL / UPDATE
  serve install                            Install llama.cpp from source
  serve install <launcher>                 Install one launcher: llama-cpp, ollama, vllm, sglang
  serve update                             Update llama.cpp
  serve update <launcher|all>              Update a specific launcher or all
  serve check                              Show version status for all installed

FIT CHECK
  serve fit <model> [ctx]                  Run llmfit fit check (default ctx=65536)

CATALOG
  serve register <alias> <path>            Register model (launcher=llama-cpp)
           [--launcher llama-cpp|ollama|vllm|sglang]
           [--port N]
  serve catalog                            Show registered aliases

LAUNCH
  serve <alias>                            Launch (detached, shows backend/port/logs)
  serve string <alias>                     Print launch string (no launch)
  serve stop <alias>                       Stop a running server
  serve list                               List running servers

HERMES MODEL ROUTING
  serve main <alias> [--ui tui|dashboard|gateway|desktop|herm]
                                           Launch + set main + start UI
  serve aux  <alias> [--ui tui|dashboard|gateway|desktop|herm]
                                           Launch + set aux + start UI
  serve herm <alias>                       Launch + main + herm TUI + hermes
  serve herm aux <alias>                   Launch + aux + herm TUI + hermes

NVIDIA NIM API (curated, 5 models)
  serve api list                           Show the curated NVIDIA NIM list
  serve api use <rank|api_id> [main|aux]   Wire a NIM model into Hermes config

SHELL ALIASES (installed to ~/.bashrc):
  name <alias> <path> [--launcher ...]     Register a model alias
  serve <alias>                            Launch + show backend/port/logs
  serve main <alias>                       Launch + main + hermes TUI
  serve main <alias> --ui dashboard        Launch + main + web dashboard
  serve main <alias> --ui gateway          Launch + main + hermes gateway
  serve aux <alias> [--ui ...]             Launch + aux + chosen UI
  serve herm <alias>                       Launch + main + herm + hermes
  serve herm aux <alias>                   Launch + aux + herm + hermes
EOF
}

# ---- Parse top-level flags (only --ui VALUE and --gateway;
#      other flags pass through to subcommands like register's --launcher) ----

UI=""
gateway_flag=0
positional=()
while [ $# -gt 0 ]; do
    case "$1" in
        --ui)
            UI="$2"
            shift 2
            ;;
        --ui=*)
            UI="${1#--ui=}"
            shift
            ;;
        --gateway|-gateway)
            gateway_flag=1
            shift
            ;;
        *)
            positional+=("$1")
            shift
            ;;
    esac
done
if [ "${gateway_flag}" = "1" ] && [ -z "${UI}" ]; then
    UI="gateway"
fi
set -- "${positional[@]+"${positional[@]}"}"

cmd="${1:-help}"
shift || true

case "${cmd}" in
    install)        install_launcher "${1:-llama-cpp}" ;;
    update)         update_all_launchers "${1:-llama-cpp}" ;;
    check)          check_llama_cpp ;;
    fit)            check_fit "$@" ;;
    string)
        info=$(alias_info "${1:-}" 2>/dev/null) || { echo "Usage: serve string <alias>"; exit 1; }
        generate_string "${1}"
        ;;
    stop)           stop_server "${1:-}" ;;
    list|ls|ps)     list_running ;;
    catalog)        list_catalog ;;
    register|name)  register_alias "$@" ;;
    main)           serve_main "${1:-}" ;;
    aux)            serve_aux "${1:-}" ;;
    herm)           shift; serve_herm "$@" ;;
    api)
        shift
        case "${1:-list}" in
            list) nvidia_nim_list ;;
            use)  shift; nvidia_nim_use "${1:-}" "${2:-main}" ;;
            *)    echo "Usage: serve api {list|use <rank|api_id> [main|aux]}"; exit 1 ;;
        esac
        ;;
    help|*)
        if alias_exists "${cmd}" 2>/dev/null; then
            launch_server "${cmd}"
        else
            usage
        fi
        ;;
esac
