#!/usr/bin/env bash
# serve — turbofit model launcher + Hermes-Agent config manager
# Part of the turbofit skill: github.com/SouthpawIN/turbofit
#
# v5.0.0: opinionated unified backend.
#   - Extended catalog schema (mmproj, gpu, presets, extra_args, tier, featured, etc.)
#   - Named flag presets (nextn, draft-mtp, turbo4-kv, vision-mmproj, no-mmap)
#   - Scaling ladder (serve auto / serve downscale) — probes VRAM, shrinks ctx,
#     drops aux, swaps tier, offloads experts
#   - Opinionated defaults: 64K ctx floor, 25 tok/s target, vision if possible,
#     tier ladder s → f → c
#
# Backwards compatible with v4 (catalog extends schema, not replaces).

set -euo pipefail

TURBOFIT_ROOT="${TURBOFIT_ROOT:-${HOME}/.local/share/turbofit}"
TURBOFIT_CONFIG_DIR="${HOME}/.config/turbofit"
CATALOG="${TURBOFIT_CONFIG_DIR}/models.yaml"
CURATED="${TURBOFIT_CONFIG_DIR}/curated.yaml"

# Resolve Hermes config path — works on standard, profile, and Docker installs
if [ -n "${HERMES_HOME:-}" ]; then
    HERMES_CONFIG="${HERMES_HOME}/config.yaml"
else
    HERMES_CONFIG="${HOME}/.hermes/config.yaml"
fi
NVIDIA_API_BASE="https://integrate.api.nvidia.com/v1"

mkdir -p "${TURBOFIT_ROOT}"/{logs,pid,port,strings,launchers} "${TURBOFIT_CONFIG_DIR}"

# Export paths for embedded Python heredocs
export TURBOFIT_CATALOG="${CATALOG}"
export TURBOFIT_CURATED="${CURATED}"
export TURBOFIT_HERMES_CONFIG="${HERMES_CONFIG}"

# Bootstrap empty catalog + curated slots if missing (first run)
if [ ! -f "${CATALOG}" ]; then
    cat > "${CATALOG}" <<'YAML'
# turbofit model catalog
# Register models with: serve register <alias> <path> [--launcher llama-cpp] [--port N]
# Or edit this file directly.
# Schema: https://github.com/SouthpawIN/turbofit#catalog-schema
models: {}
YAML
fi

if [ ! -f "${CURATED}" ]; then
    cat > "${CURATED}" <<'YAML'
# turbofit curated slots — used by `serve auto` to pick models
# Each slot has tier keys (s/sf/sd/f/c) with lists of entries.
# Edit to match your local models and API preferences.
slots:
  # LOCAL MAIN — your GPU models, ranked by tier
  main_local:
    description: Local main — runs on your GPU. Register models with `serve register`.
    # Uncomment and set to your models:
    # s:
    # - alias: my-27b-model
    #   why: Smartest model I have
    #   tok_s_target: 38
    #   ctx_target: 262144
    #   vision: true
    #   vram_gb: 17

  # LOCAL AUX — secondary model for vision/aux tasks
  aux_local:
    description: Local aux — secondary model (vision, compression, etc.)
    # sd:
    # - alias: my-35b-moe
    #   why: MoE 35B/3B-active, vision, 1M ctx
    #   tok_s_target: 110
    #   ctx_target: 262144
    #   vision: true
    #   vram_gb: 11

  # API MAIN — used when no local GPU or --api flag
  main_api:
    description: API main picks — free models first, ranked by reasoning quality.
    s:
    - alias: deepseek-v4-pro
      provider: nvidia-nim
      model_id: deepseek-ai/deepseek-v4-pro
      why: Best free reasoning + coding. 1M ctx. Free on NIM.
      vision: false
      free: true
    sf:
    - alias: deepseek-v4-flash
      provider: nvidia-nim
      model_id: deepseek-ai/deepseek-v4-flash
      why: Fast reasoning, free tier.
      vision: false
      free: true

  # API AUX — vision-capable, free first
  aux_api:
    description: API aux picks — vision required, free first.
    sf:
    - alias: minimax-m3
      provider: nvidia-nim
      model_id: minimaxai/minimax-m3
      why: Free vision model. 1M ctx, image+video.
      vision: true
      free: true
YAML
fi

# ─────────────────────────────────────────────────────────────────────────────
# Launcher registry
# ─────────────────────────────────────────────────────────────────────────────

declare -A LAUNCHER_NAME=(
    [llama-cpp]="llama.cpp (ggerganov)"
    [ollama]="Ollama"
    [vllm]="vLLM"
    [sglang]="SGlang"
)

declare -A LAUNCHER_INSTALL=(
    [llama-cpp]="llama.cpp:git_clone"
    [ollama]="ollama:curl_install"
    [vllm]="vllm:pip_install"
    [sglang]="sglang:pip_install"
)

declare -A LAUNCHER_TEMPLATE=(
    [llama-cpp]='"$BINARY" -m "$MODEL_PATH" --host "$HOST" --port "$PORT" -ngl "$NGL" -fa on -c "$CTX" --jinja'
    [ollama]='OLLAMA_HOST="$HOST:$PORT" ollama serve'
    [vllm]='vllm serve "$MODEL_PATH" --host "$HOST" --port "$PORT" --max-model-len "$CTX" --gpu-memory-utilization 0.9'
    [sglang]='python -m sglang.launch_server --model-path "$MODEL_PATH" --host "$HOST" --port "$PORT" --context-length "$CTX" --tp 1'
)

declare -A LAUNCHER_URL=(
    [llama-cpp]='http://$HOST:$PORT/v1'
    [ollama]='http://$HOST:$PORT/v1'
    [vllm]='http://$HOST:$PORT/v1'
    [sglang]='http://$HOST:$PORT/v1'
)

# ─────────────────────────────────────────────────────────────────────────────
# Named flag presets (opinionated bundles per spec-decoding / KV-cache / etc.)
# ─────────────────────────────────────────────────────────────────────────────
#
# Apply by listing `presets: [nextn, turbo4-kv]` in the catalog entry.
# Order matters; later presets can override earlier flags.

declare -A PRESET_FLAGS=(
    # Spec decoding
    [nextn]='--spec-type nextn --draft-block-size 3'
    [nextn-tight]='--spec-type nextn --draft-block-size 2'
    [draft-mtp]='--spec-type draft-mtp'
    [draft-mtp-tight]='--spec-type draft-mtp --draft-block-size 2'

    # KV cache quantization (TurboQuant fork variants)
    [turbo4-kv]='-ctk turbo4 -ctv turbo4'
    [turbo3-kv]='-ctk turbo3 -ctv turbo3'
    [turbo2-kv]='-ctk turbo2 -ctv turbo2'
    [q8-kv]='-ctk q8_0 -ctv q8_0'
    [q4-kv]='-ctk q4_0 -ctv q4_0'

    # Stability / single-GPU
    [no-mmap]='--no-mmap'
    [split-none]='--split-mode none'
    [mlock]='--mlock'
    [parallel-4]='--parallel 4'
    [parallel-2]='--parallel 2'
    [parallel-1]='--parallel 1'

    # MoE expert offload
    [cpu-moe-2]='--n-cpu-moe 2'
    [cpu-moe-4]='--n-cpu-moe 4'
    [cpu-moe-8]='--n-cpu-moe 8'
    # Multi-GPU tensor split: use extra_args: ['--tensor-split', 'X,Y'] in catalog

    # GPU selection is handled by the catalog `gpu:` field, not a flag preset
    # (kept `gpu0`/`gpu1` preset names as no-op aliases for backwards compat)

    # Vision / multimodal — handled by `mmproj:` field, not a flag
)

# ─────────────────────────────────────────────────────────────────────────────
# NVIDIA NIM curated API list (verified 2026-06-22)
# ─────────────────────────────────────────────────────────────────────────────

NVIDIA_NIM_FILE="${TURBOFIT_ROOT}/nvidia-nim-curated.yaml"
export TURBOFIT_NIM_FILE="${NVIDIA_NIM_FILE}"

