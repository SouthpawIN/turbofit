# ─────────────────────────────────────────────────────────────────────────────
# llama.cpp management
# ─────────────────────────────────────────────────────────────────────────────

ensure_llama_cpp() {
    if ! command -v llama-server >/dev/null 2>&1; then
        install_launcher llama-cpp
    fi
}

install_launcher() {
    local which="$1"
    case "${which}" in
        llama-cpp)
            local src="${HOME}/.local/src/llama.cpp"
            local prefix="${HOME}/.local"
            mkdir -p "${src%/*}"
            if [ ! -d "${src}/.git" ]; then
                echo "Cloning llama.cpp..."
                git clone https://github.com/ggerganov/llama.cpp.git "${src}"
            fi
            cd "${src}"
            git pull --rebase --autostash 2>/dev/null || git pull --rebase
            cmake -B build -DCMAKE_BUILD_TYPE=Release -DGGML_CUDA=ON \
                -DCMAKE_INSTALL_PREFIX="${prefix}"
            cmake --build build --config Release -j"$(nproc)"
            cmake --install build
            export PATH="${prefix}/bin:${PATH}"
            echo "✓ llama.cpp installed"
            ;;
        ollama)
            echo "Installing Ollama..."
            curl -fsSL https://ollama.com/install.sh | sh
            echo "✓ Ollama installed"
            ;;
        vllm)
            echo "Installing vllm (pip)..."
            pip install -U vllm
            echo "✓ vllm installed"
            ;;
        sglang)
            echo "Installing SGlang (pip)..."
            pip install -U "sglang[all]"
            echo "✓ SGlang installed"
            ;;
        *)
            echo "✗ Unknown launcher: ${which}"
            echo "  Supported: ${!LAUNCHER_NAME[*]}"
            return 1
            ;;
    esac
}

update_llama_cpp() {
    local src="${HOME}/.local/src/llama.cpp"
    if [ ! -d "${src}/.git" ]; then
        install_launcher llama-cpp
        return
    fi
    echo "Updating llama.cpp..."
    cd "${src}"
    git fetch origin
    git pull --rebase --autostash 2>/dev/null || git pull --rebase
    cmake --build build --config Release -j"$(nproc)"
    cmake --install build
    echo "✓ llama.cpp updated"
}

update_all_launchers() {
    local target="${1:-all}"
    if [ "${target}" = "all" ]; then
        for l in "${!LAUNCHER_NAME[@]}"; do
            echo "--- Updating ${l} ---"
            case "${l}" in
                llama-cpp) update_llama_cpp ;;
                ollama)    install_launcher ollama ;;
                vllm)      pip install -U vllm ;;
                sglang)    pip install -U "sglang[all]" ;;
            esac
        done
    else
        case "${target}" in
            llama-cpp) update_llama_cpp ;;
            ollama)    install_launcher ollama ;;
            vllm)      pip install -U vllm ;;
            sglang)    pip install -U "sglang[all]" ;;
            *) echo "Unknown launcher: ${target}"; return 1 ;;
        esac
    fi
}

check_llama_cpp() {
    local binary_version
    binary_version=$(llama-server --version 2>/dev/null | head -1 || echo "not in PATH")
    echo "llama.cpp: ${binary_version}"
    local src="${HOME}/.local/src/llama.cpp"
    if [ -d "${src}/.git" ]; then
        local current remote
        current=$(cd "${src}" && git rev-parse --short HEAD)
        remote=$(cd "${src}" && git rev-parse --short origin/master 2>/dev/null) || remote="unknown"
        echo "  local commit:  ${current}"
        echo "  remote commit: ${remote}"
        [ "${current}" != "${remote}" ] && echo "  status: OUT OF DATE — run 'serve update'" || echo "  status: up to date"
    fi
    echo ""
    echo "Other launchers:"
    for l in ollama vllm sglang; do
        local ver="missing"
        command -v "${l}" >/dev/null 2>&1 && ver="$(${l} --version 2>&1 | head -1 || echo 'present')"
        printf "  %-10s %s\n" "${l}:" "${ver}"
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# Hardware fit check
# ─────────────────────────────────────────────────────────────────────────────

check_fit() {
    local model_ref="$1"
    local requested_ctx="${2:-65536}"
    if ! command -v llmfit >/dev/null 2>&1; then
        echo "llmfit not installed. Run: pip install -U llmfit"
        return 1
    fi
    llmfit plan "${model_ref}" --context "${requested_ctx}" --json
}

# ─────────────────────────────────────────────────────────────────────────────
# VRAM probe (live, not llmfit)
# ─────────────────────────────────────────────────────────────────────────────

probe_vram() {
    # Returns: total_MiB free_MiB gpu_count gpu0_free gpu1_free
    python3 - <<'PYEOF'
import subprocess, json, sys
try:
    out = subprocess.check_output(
        ["nvidia-smi", "--query-gpu=index,memory.used,memory.total",
         "--format=csv,noheader,nounits"],
        timeout=5
    ).decode().strip().splitlines()
    gpus = []
    total_used = 0
    total_cap = 0
    per_gpu_free = []
    for line in out:
        idx, used, cap = [int(x.strip()) for x in line.split(",")]
        gpus.append((idx, used, cap))
        total_used += used
        total_cap += cap
        per_gpu_free.append(cap - used)
    total_free = total_cap - total_used
    print(json.dumps({
        "gpu_count": len(gpus),
        "total_MiB": total_cap,
        "used_MiB": total_used,
        "free_MiB": total_free,
        "free_GB": round(total_free / 1024, 1),
        "per_gpu_free_MiB": per_gpu_free,
    }))
except Exception as e:
    print(json.dumps({"error": str(e)}), file=sys.stderr)
    sys.exit(1)
PYEOF
}

# ─────────────────────────────────────────────────────────────────────────────
# Alias lookup (extended schema)
# ─────────────────────────────────────────────────────────────────────────────

alias_info() {
    local alias="$1"
    python3 - "$alias" <<'PYEOF'
import sys, os, yaml
alias = sys.argv[1]
catalog = os.environ.get("TURBOFIT_CATALOG", os.path.expanduser("~/.config/turbofit/models.yaml"))
if not os.path.exists(catalog):
    print("", file=sys.stderr); sys.exit(1)
with open(catalog) as f:
    cfg = yaml.safe_load(f) or {}
models = cfg.get("models", {})

# Resolve alias
m = models.get(alias)
if not m:
    for canonical, info in models.items():
        if alias in (info.get("aliases") or []):
            m = info
            alias = canonical
            break
if not m:
    print("", file=sys.stderr); sys.exit(1)

print(m.get("launcher", "llama-cpp"),
      m.get("path", ""),
      m.get("port", 8080),
      m.get("ctx", 65536))
PYEOF
}

alias_full() {
    local alias="$1"
    python3 - "$alias" <<'PYEOF'
import sys, os, yaml, json
alias = sys.argv[1]
catalog = os.environ.get("TURBOFIT_CATALOG", os.path.expanduser("~/.config/turbofit/models.yaml"))
if not os.path.exists(catalog):
    print("{}", file=sys.stderr); sys.exit(1)
with open(catalog) as f:
    cfg = yaml.safe_load(f) or {}
models = cfg.get("models", {})
m = models.get(alias)
if not m:
    for canonical, info in models.items():
        if alias in (info.get("aliases") or []):
            m = info; alias = canonical; break
if not m:
    print("{}", file=sys.stderr); sys.exit(1)
print(json.dumps({"alias": alias, **m}))
PYEOF
}

alias_exists() {
    [ -n "$(alias_info "$1" 2>/dev/null)" ]
}

# ─────────────────────────────────────────────────────────────────────────────
# Generate launch string — extended
# ─────────────────────────────────────────────────────────────────────────────

resolve_extra_args() {
    local alias="$1"
    python3 - "$alias" <<'PYEOF'
import sys, os, yaml
alias = sys.argv[1]
catalog = os.environ.get("TURBOFIT_CATALOG", os.path.expanduser("~/.config/turbofit/models.yaml"))
if not os.path.exists(catalog):
    sys.exit(0)
with open(catalog) as f:
    cfg = yaml.safe_load(f) or {}
models = cfg.get("models", {})
m = models.get(alias)
if not m:
    for canonical, info in models.items():
        if alias in (info.get("aliases") or []):
            m = info; break
if not m:
    sys.exit(0)

# 1) explicit extra_args first (raw flag list)
for a in (m.get("extra_args") or []):
    print(a)

# 2) named presets — resolve to flag strings
for p in (m.get("presets") or []):
    # Resolve preset names via shell-side PRESET_FLAGS (we'll pass through below)
    print(f"__PRESET__{p}")

# 3) GPU selection (from catalog `gpu:` field)
gpu = m.get("gpu")
if gpu is not None:
    print(f"--main-gpu {gpu}")

# 4) mmproj
if m.get("mmproj"):
    print(f"--mmproj {m['mmproj']}")

# 5) parallel override
if m.get("parallel"):
    print(f"--parallel {m['parallel']}")

# 6) binary hint (only emitted as a marker — resolved in shell)
if m.get("binary"):
    print(f"__BINARY__{m['binary']}")
PYEOF
}

generate_string() {
    local alias="$1"
    local info launcher path port ctx
    info=$(alias_info "${alias}")
    [ -z "${info}" ] && { echo "✗ Unknown alias: ${alias}"; return 1; }
    launcher=$(echo "${info}" | awk '{print $1}')
    path=$(echo "${info}"     | awk '{print $2}')
    port=$(echo "${info}"     | awk '{print $3}')
    ctx=$(echo "${info}"      | awk '{print $4}')
    ctx=$(( ctx < 65536 ? 65536 : ctx ))

    local host="127.0.0.1"
    local ngl=99

    # Look up catalog binary hint
    local binary=""
    local catalog_json
    catalog_json=$(alias_full "${alias}" 2>/dev/null || true)
    if [ -n "${catalog_json}" ]; then
        binary=$(echo "${catalog_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('binary','') or '')" 2>/dev/null || echo "")
    fi
    if [ -z "${binary}" ]; then
        binary="llama-server"
    fi

    case "${launcher}" in
        llama-cpp)
            echo "# turbofit launch string for ${alias}"
            echo "# $(alias_full "${alias}" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(d.get('description',''))" 2>/dev/null || true)"
            echo "# binary: ${binary}"
            echo "${binary} \\"
            echo "  -m \"${path}\" \\"
            echo "  --host ${host} --port ${port} \\"
            echo "  -ngl ${ngl} -fa on \\"
            echo "  -c ${ctx} \\"
            echo "  --jinja \\"
            echo "  -t $(nproc) \\"
            # Inject resolved extras (presets + extra_args + mmproj + gpu)
            local extras
            extras=$(resolve_extra_args "${alias}" 2>/dev/null || true)
            local in_extras=0
            while IFS= read -r line; do
                [[ -z "${line}" ]] && continue
                if [[ "${line}" == __PRESET__* ]]; then
                    local pname="${line#__PRESET__}"
                    if [[ -n "${PRESET_FLAGS[${pname}]-}" ]] && [[ -n "${PRESET_FLAGS[${pname}]}" ]]; then
                        echo "  ${PRESET_FLAGS[${pname}]} \\"
                    fi
                elif [[ "${line}" == __BINARY__* ]]; then
                    : # binary already emitted in header
                else
                    echo "  ${line} \\"
                fi
            done <<< "${extras}"
            echo "  # end turbofit"
            ;;
        ollama)
            cat <<EOF
# Pull the model first (one-time)
ollama pull ${path}

# Launch Ollama server
OLLAMA_HOST="${host}:${port}" ollama serve
EOF
            ;;
        vllm)
            cat <<EOF
vllm serve ${path} \\
  --host ${host} \\
  --port ${port} \\
  --max-model-len ${ctx} \\
  --gpu-memory-utilization 0.9 \\
  --served-model-name ${alias}
EOF
            ;;
        sglang)
            cat <<EOF
python -m sglang.launch_server \\
  --model-path ${path} \\
  --host ${host} \\
  --port ${port} \\
  --context-length ${ctx} \\
  --served-model-name ${alias} \\
  --tp 1
EOF
            ;;
    esac
}

# ─────────────────────────────────────────────────────────────────────────────
# Server lifecycle
# ─────────────────────────────────────────────────────────────────────────────

launch_server() {
    local alias="$1"
    local info launcher path port ctx
    info=$(alias_info "${alias}")
    [ -z "${info}" ] && { echo "✗ Unknown alias: ${alias}"; return 1; }
    launcher=$(echo "${info}" | awk '{print $1}')
    path=$(echo "${info}"     | awk '{print $2}')
    port=$(echo "${info}"     | awk '{print $3}')
    ctx=$(echo "${info}"      | awk '{print $4}')

    # Kill any existing process on this port (or tracked alias)
    if [ -f "${TURBOFIT_ROOT}/pid/${alias}" ]; then
        local old_pid
        old_pid=$(cat "${TURBOFIT_ROOT}/pid/${alias}")
        if kill -0 "${old_pid}" 2>/dev/null; then
            echo "Stopping existing ${alias} (pid ${old_pid})..."
            kill "${old_pid}" 2>/dev/null || true
            sleep 1
            kill -9 "${old_pid}" 2>/dev/null || true
        fi
        rm -f "${TURBOFIT_ROOT}/pid/${alias}" "${TURBOFIT_ROOT}/port/${alias}"
    fi

    # Look up catalog binary hint
    local binary=""
    local catalog_json
    catalog_json=$(alias_full "${alias}" 2>/dev/null || true)
    if [ -n "${catalog_json}" ]; then
        binary=$(echo "${catalog_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('binary','') or '')" 2>/dev/null || echo "")
    fi
    if [ -z "${binary}" ]; then
        binary="llama-server"
    fi

    local cmd_file="${TURBOFIT_ROOT}/strings/${alias}.sh"
    generate_string "${alias}" > "${cmd_file}"
    chmod +x "${cmd_file}"

    local log_file="${TURBOFIT_ROOT}/logs/${alias}.log"
    local host="127.0.0.1"
    local ngl=99
    ctx=$(( ctx < 65536 ? 65536 : ctx ))

    # Resolve extras as flat args
    local extra_args=()
    local extras
    extras=$(resolve_extra_args "${alias}" 2>/dev/null || true)
    while IFS= read -r line; do
        [[ -z "${line}" ]] && continue
        if [[ "${line}" == __PRESET__* ]]; then
            local pname="${line#__PRESET__}"
            if [[ -n "${PRESET_FLAGS[${pname}]-}" ]] && [[ -n "${PRESET_FLAGS[${pname}]}" ]]; then
                # shellcheck disable=SC2206
                extra_args+=(${PRESET_FLAGS[${pname}]})
            fi
        elif [[ "${line}" == __BINARY__* ]]; then
            : # already handled above
        else
            # shellcheck disable=SC2206
            extra_args+=(${line})
        fi
    done <<< "${extras}"

    case "${launcher}" in
        llama-cpp)
            nohup "${binary}" \
                -m "${path}" \
                --host "${host}" --port "${port}" \
                -ngl "${ngl}" -fa on \
                -c "${ctx}" \
                --jinja \
                -t "$(nproc)" \
                "${extra_args[@]}" \
                > "${log_file}" 2>&1 &
            ;;
        ollama)
            OLLAMA_HOST="${host}:${port}" nohup ollama serve > "${log_file}" 2>&1 &
            ;;
        vllm)
            nohup vllm serve "${path}" \
                --host "${host}" --port "${port}" \
                --max-model-len "${ctx}" --gpu-memory-utilization 0.9 \
                --served-model-name "${alias}" "${extra_args[@]}" \
                > "${log_file}" 2>&1 &
            ;;
        sglang)
            nohup python -m sglang.launch_server \
                --model-path "${path}" \
                --host "${host}" --port "${port}" \
                --context-length "${ctx}" \
                --served-model-name "${alias}" --tp 1 "${extra_args[@]}" \
                > "${log_file}" 2>&1 &
            ;;
    esac

    disown
    local pid=$!
    echo "${pid}" > "${TURBOFIT_ROOT}/pid/${alias}"
    echo "${port}" > "${TURBOFIT_ROOT}/port/${alias}"

    echo "Launching ${alias} (pid ${pid}) via ${launcher} on :${port}..."
    for i in $(seq 1 120); do
        if curl -sf "http://127.0.0.1:${port}/health" >/dev/null 2>&1 || \
           curl -sf "http://127.0.0.1:${port}/v1/models" >/dev/null 2>&1; then
            echo ""
            echo "✓ ${alias} ready"
            echo ""
            echo "  Backend: ${launcher}"
            echo "  Port:   :${port}"
            echo "  PID:    ${pid}"
            echo "  Logs:   ${log_file}"
            echo "  Stop:   serve stop ${alias}"
            return 0
        fi
        if ! kill -0 "${pid}" 2>/dev/null; then
            echo ""
            echo "✗ ${alias} died during startup. Tail of log:"
            tail -20 "${log_file}" 2>/dev/null || true
            return 1
        fi
        sleep 1
    done
    echo ""
    echo "✗ ${alias} did not become healthy within 120s"
    echo "  Logs: ${log_file}"
    return 1
}

stop_server() {
    local alias="$1"
    local stopped=0
    # Try systemd daemon first (turbofit-<alias>.service)
    if systemctl --user is-active "turbofit-${alias}.service" >/dev/null 2>&1; then
        systemctl --user stop "turbofit-${alias}.service" 2>/dev/null
        echo "✓ Stopped ${alias} (systemd daemon)"
        stopped=1
    fi
    # Also check PID-file managed servers (direct serve launches)
    if [ -f "${TURBOFIT_ROOT}/pid/${alias}" ]; then
        local pid
        pid=$(cat "${TURBOFIT_ROOT}/pid/${alias}")
        if kill -0 "${pid}" 2>/dev/null; then
            kill "${pid}" 2>/dev/null || true
            sleep 1
            kill -9 "${pid}" 2>/dev/null || true
        fi
        rm -f "${TURBOFIT_ROOT}/pid/${alias}" "${TURBOFIT_ROOT}/port/${alias}"
        echo "✓ Stopped ${alias} (pid ${pid})"
        stopped=1
    fi
    [ "$stopped" -eq 0 ] && echo "No running server for: ${alias}"
}

stop_all() {
    # Stop systemd-managed daemons
    while IFS= read -r svc; do
        local alias
        alias=$(echo "$svc" | sed 's/turbofit-//; s/\.service//')
        stop_server "${alias}"
    done < <(systemctl --user list-units --all --no-legend 2>/dev/null | grep -o 'turbofit-[^ ]*\.service' | sort -u)
    # Stop PID-file managed servers (direct serve launches)
    if [ -d "${TURBOFIT_ROOT}/pid" ]; then
        for pid_file in "${TURBOFIT_ROOT}/pid"/*; do
            [ -f "${pid_file}" ] || continue
            local alias
            alias=$(basename "${pid_file}")
            stop_server "${alias}"
        done
    fi
}

list_running() {
    echo "Running servers:"
    local found=0
    # PID-file managed (direct serve launches)
    if [ -d "${TURBOFIT_ROOT}/pid" ]; then
        for pid_file in "${TURBOFIT_ROOT}/pid"/*; do
            [ -f "${pid_file}" ] || continue
            local alias pid port
            alias=$(basename "${pid_file}")
            pid=$(cat "${pid_file}")
            port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo "?")
            if kill -0 "${pid}" 2>/dev/null; then
                echo "  ${alias}: pid ${pid}, :${port}"
                found=1
            else
                rm -f "${pid_file}"
            fi
        done
    fi
    # systemd-managed daemons (turbofit-<alias>.service)
    while IFS= read -r svc; do
        local alias
        alias=$(echo "$svc" | sed 's/turbofit-//; s/\.service//')
        local port
        port=$(systemctl --user cat "turbofit-${alias}.service" 2>/dev/null | grep '^ExecStart=' | grep -oE '[0-9]+' | head -1)
        local state
        state=$(systemctl --user is-active "turbofit-${alias}.service" 2>/dev/null)
        echo "  ${alias}: systemd (${state}), :${port:-?}"
        found=1
    done < <(systemctl --user list-units --all --no-legend 2>/dev/null | grep -o 'turbofit-[^ ]*\.service' | sort -u)
    [ "$found" -eq 0 ] && echo "  (none)"
    # Also scan ports for rogue llama-servers (started manually outside turbofit)
    echo ""
    echo "Detected llama-server processes on any port:"
    for p in $(ss -ltn 2>/dev/null | awk '{print $4}' | grep -oE ':[0-9]+' | tr -d ':' | sort -nu); do
        if curl -sf --max-time 2 "http://127.0.0.1:${p}/v1/models" >/dev/null 2>&1; then
            local model_id
            model_id=$(curl -sf --max-time 2 "http://127.0.0.1:${p}/v1/models" 2>/dev/null \
                | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data'][0]['id'] if d.get('data') else '?')" 2>/dev/null || echo "?")
            echo "  :${p}  →  ${model_id}"
        fi
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# Scaling ladder — opinionated "serve auto" / "serve downscale"
# ─────────────────────────────────────────────────────────────────────────────
#
# Tier ladder:
#   s-tier  = smartest (e.g. Darwin Reason, DeepSeek V4 Pro)
#   sf-tier = smartest-fast (Prism Eagle, Qwopus v2-MTP, Darwin Apex)
#   f-tier  = fastest (Qwopus Coder-MTP)
#   sd-tier = smart-dense (Carnice Apex Nano, MiniMax M3 API)
#   c-tier  = cheap (OmniStep-SFT-8B, Nemotron Ultra API)
#
# Targets (opinionated):
#   ctx_floor        = 65536    # Hermes-Agent hard floor
#   tok_s_floor      = 25       # min acceptable tok/s for main
#   want_vision      = False    # user flag
#   want_vision_main = True     # preferred (but optional)
#
# Downscale steps (each step tries to free VRAM without dropping tok/s below floor):
#   1. shrink ctx: 262144 → 131072 → 65536 (floor)
#   2. drop aux (free the aux model's VRAM)
#   3. tier swap: s → sf → f
#   4. swap to MoE: any dense → darwin-apex (MoE, expert offload)
#   5. expert offload (MoE): --cpu-moe or ngl reduction
#   6. drop quant: Q4 → Q3 (catalog swap — not auto yet)
#   7. CPU-only fallback (last resort)

pick_from_curated() {
    # Walk the curated.yaml slots (main_local → main_api, or aux_local → aux_api)
    # Pick the highest-tier entry that meets constraints.
    # Returns: {type: "local"|"api", alias?: str, model_id?: str, provider?: str, base_url?: str, api_key_env?: str, vision?: bool, free?: bool}
    local role="${1:-main}"
    local want_vision="${2:-false}"
    local prefer_free="${3:-false}"
    python3 - "$role" "$want_vision" "$prefer_free" <<'PYEOF'
import sys, os, yaml, json
slot = sys.argv[1]             # "main" or "aux"
want_vision = sys.argv[2] == "true"
prefer_free = sys.argv[3] == "true"

curated_path = os.environ.get("TURBOFIT_CURATED", os.path.expanduser("~/.config/turbofit/curated.yaml"))
catalog_path = os.environ.get("TURBOFIT_CATALOG", os.path.expanduser("~/.config/turbofit/models.yaml"))

if not os.path.exists(curated_path):
    print(json.dumps({"error": "curated.yaml missing"})); sys.exit(1)
with open(curated_path) as f:
    curated = yaml.safe_load(f) or {}
catalog_models = {}
if os.path.exists(catalog_path):
    with open(catalog_path) as f:
        catalog = yaml.safe_load(f) or {}
    catalog_models = (catalog or {}).get("models", {})

# Fallback chain: main_local → main_api, aux_local → aux_api
chain = ["main_local", "main_api"] if slot == "main" else ["aux_local", "aux_api"]
tier_rank = {"s": 0, "sf": 1, "sd": 2, "f": 3, "c": 4}

def model_path_exists(p):
    return p and os.path.exists(p)

def meets(entry, vision_required):
    if vision_required and not entry.get("vision", False):
        return False
    if prefer_free and entry.get("free") is False:
        return False
    return True

# Walk chain, then tiers within each slot
for slot_key in chain:
    slot_data = curated.get("slots", {}).get(slot_key, {})
    entries_by_tier = []  # (tier_rank, idx, entry_dict, entry_kind)
    for tier_name in ["s", "sf", "sd", "f", "c"]:
        for idx, e in enumerate(slot_data.get(tier_name, [])):
            entries_by_tier.append((tier_rank[tier_name], idx, e, "local" if "local" in slot_key else "api"))

    entries_by_tier.sort(key=lambda x: (x[0], x[1]))

    for tr, idx, e, kind in entries_by_tier:
        if not meets(e, want_vision):
            continue
        if kind == "local":
            alias = e.get("alias")
            if not alias:
                continue
            m = catalog_models.get(alias, {})
            if not m:
                continue
            path = m.get("path", "")
            if not model_path_exists(path):
                continue
            print(json.dumps({
                "type": "local",
                "slot": slot_key,
                "tier": ["s","sf","sd","f","c"][tr],
                "alias": alias,
                "path": path,
                "port": m.get("port"),
                "ctx": m.get("ctx"),
                "binary": m.get("binary"),
                "vision": e.get("vision", False),
                "reason": f"{slot_key} tier={['s','sf','sd','f','c'][tr]} ({e.get('why','')[:80]})",
            }))
            sys.exit(0)
        else:  # api
            print(json.dumps({
                "type": "api",
                "slot": slot_key,
                "tier": ["s","sf","sd","f","c"][tr],
                "alias": e.get("alias"),
                "provider": e.get("provider"),
                "model_id": e.get("model_id"),
                "vision": e.get("vision", False),
                "free": e.get("free", False),
                "reason": f"{slot_key} tier={['s','sf','sd','f','c'][tr]} ({e.get('why','')[:80]})",
            }))
            sys.exit(0)

print(json.dumps({"pick": None, "reason": "no candidate met constraints in any slot"}))
PYEOF
}

# ─────────────────────────────────────────────────────────────────────────────
# API model picker — reads curated.yaml API slots, ranks by tier
# ─────────────────────────────────────────────────────────────────────────────

pick_api_model() {
    local role="${1:-main}"
    local want_vision="${2:-false}"
    local prefer_free="${3:-false}"
    python3 - "$role" "$want_vision" "$prefer_free" <<'PYEOF'
import sys, os, yaml, json

role = sys.argv[1]
want_vision = sys.argv[2] == "true"
prefer_free = sys.argv[3] == "true"

curated_path = os.environ.get("TURBOFIT_CURATED", os.path.expanduser("~/.config/turbofit/curated.yaml"))
if not os.path.exists(curated_path):
    print(json.dumps({"error": "curated.yaml missing"}))
    sys.exit(1)

with open(curated_path) as f:
    curated = yaml.safe_load(f) or {}

slot_key = "main_api" if role == "main" else "aux_api"
slot_data = curated.get("slots", {}).get(slot_key, {})

tier_rank = {"s": 0, "sf": 1, "sd": 2, "f": 3, "c": 4}
entries = []
for tier_name in ["s", "sf", "sd", "f", "c"]:
    for idx, e in enumerate(slot_data.get(tier_name, [])):
        entries.append((tier_rank[tier_name], idx, e))

entries.sort(key=lambda x: (x[0], x[1]))

for tr, idx, e in entries:
    # Vision filter
    if want_vision and not e.get("vision", False):
        continue
    # Free filter
    if prefer_free and e.get("free") is False:
        continue
    print(json.dumps({
        "type": "api",
        "slot": slot_key,
        "tier": ["s","sf","sd","f","c"][tr],
        "alias": e.get("alias"),
        "provider": e.get("provider"),
        "model_id": e.get("model_id"),
        "vision": e.get("vision", False),
        "free": e.get("free", False),
        "price_input": e.get("price_input"),
        "price_output": e.get("price_output"),
        "reason": f"{slot_key} tier={['s','sf','sd','f','c'][tr]} ({e.get('why','')[:80]})",
    }))
    sys.exit(0)

print(json.dumps({"error": f"no API candidate met constraints for {role}"}))
PYEOF
}

wire_hermes_api_main() {
    local model_id="$1"
    local base_url="$2"
    local api_key_env="$3"
    python3 - <<PYEOF
import yaml, os
cfg_path = "${HERMES_CONFIG}"
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("model", {})
cfg["model"]["default"] = "${model_id}"
cfg["model"]["base_url"] = "${base_url}"
cfg["model"]["api_key"] = "${api_key_env}"
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Hermes main (API): ${model_id} @ ${base_url} (key=\${${api_key_env}})"
}

wire_hermes_api_aux() {
    local model_id="$1"
    local base_url="$2"
    local api_key_env="$3"
    local tasks=(vision web_extract compression session_search skills_hub approval mcp title_generation curator)
    python3 - <<PYEOF
import yaml, os
cfg_path = "${HERMES_CONFIG}"
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("auxiliary", {})
tasks = ${tasks[@]@Q}
for task in tasks:
    cfg["auxiliary"].setdefault(task, {})
    cfg["auxiliary"][task]["provider"] = "custom:api"
    cfg["auxiliary"][task]["base_url"] = "${base_url}"
    cfg["auxiliary"][task]["api_key"] = "${api_key_env}"
    cfg["auxiliary"][task]["model"] = "${model_id}"
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Hermes aux (API): ${model_id} @ ${base_url} (key=\${${api_key_env}})"
}

# Provider base URLs + key env vars
declare -A API_BASE_URL=(
    [openrouter]="https://openrouter.ai/api/v1"
    [nvidia-nim]="https://integrate.api.nvidia.com/v1"
    [anthropic]="https://api.anthropic.com/v1"
    [openai]="https://api.openai.com/v1"
)
declare -A API_KEY_ENV=(
    [openrouter]="OPENROUTER_API_KEY"
    [nvidia-nim]="NVIDIA_API_KEY"
    [anthropic]="ANTHROPIC_API_KEY"
    [openai]="OPENAI_API_KEY"
)

serve_auto() {
    local role="main"
    local want_vision="false"
    local prefer_free="false"
    local force_api="false"

    # Parse: serve_auto [main|aux] [--vision] [--free] [--api] [--ui ...]
    while [ $# -gt 0 ]; do
        case "$1" in
            main|aux) role="$1"; shift ;;
            --vision) want_vision="true"; shift ;;
            --free)   prefer_free="true"; shift ;;
            --api)    force_api="true"; shift ;;
            *) shift ;;
        esac
    done

    # If --api flag or no NVIDIA GPU detected, skip local and go straight to API
    if [ "${force_api}" = "true" ]; then
        echo "→ API mode forced. Skipping local catalog."
    elif ! command -v nvidia-smi >/dev/null 2>&1; then
        echo "→ No NVIDIA GPU detected. Defaulting to API mode."
        force_api="true"
    else
        # Check VRAM — if <8GB free, suggest API
        local vram_json
        vram_json=$(probe_vram 2>/dev/null || echo '{"free_GB":0}')
        local free_gb
        free_gb=$(echo "${vram_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('free_GB',0))" 2>/dev/null || echo "0")
        local total_gb
        total_gb=$(echo "${vram_json}" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(round(d.get('total_MiB',0)/1024,1))" 2>/dev/null || echo "0")

        if awk "BEGIN{exit !(${total_gb} < 8)}"; then
            echo "→ GPU VRAM too small (${total_gb}GB total). Defaulting to API mode."
            echo "  Recommended: API main (DeepSeek V4 Pro, free on NIM) + API aux (Kimi K2.6, free)"
            force_api="true"
        elif awk "BEGIN{exit !(${total_gb} < 16)}"; then
            echo "→ Modest GPU (${total_gb}GB). Can run local aux with cpu-moe, or API main + local aux."
            echo "  Recommended: API main (DeepSeek V4 Pro) + local aux (Carnice with cpu-moe)"
            echo "  Alternative: Small local main (Prism Eagle 14GB) + API aux"
        elif [ "${free_gb}" != "?" ] && awk "BEGIN{exit !(${free_gb} < 8)}"; then
            echo "→ Tight VRAM (${free_gb}GB free of ${total_gb}GB). Consider API aux to free space."
        fi
    fi

    # If API mode, pick from curated API slots directly
    if [ "${force_api}" = "true" ]; then
        local pick_json
        pick_json=$(pick_api_model "${role}" "${want_vision}" "${prefer_free}")
        local pick_provider pick_model_id pick_alias pick_base_url pick_key_env
        pick_provider=$(echo "${pick_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('provider',''))" 2>/dev/null || echo "")
        pick_model_id=$(echo "${pick_json}"  | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('model_id',''))" 2>/dev/null || echo "")
        pick_alias=$(echo "${pick_json}"     | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('alias',''))" 2>/dev/null || echo "")
        local pick_reason
        pick_reason=$(echo "${pick_json}"    | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('reason',''))" 2>/dev/null || echo "")

        pick_base_url="${API_BASE_URL[${pick_provider:-unknown}]:-https://openrouter.ai/api/v1}"
        pick_key_env="${API_KEY_ENV[${pick_provider:-unknown}]:-OPENROUTER_API_KEY}"

        echo "→ Auto-pick for ${role} (API): ${pick_alias}"
        echo "  Provider: ${pick_provider}  Model: ${pick_model_id}"
        echo "  ${pick_reason}"
        echo ""

        if [ "${role}" = "main" ]; then
            wire_hermes_api_main "${pick_model_id}" "${pick_base_url}" "${pick_key_env}"
        else
            wire_hermes_api_aux "${pick_model_id}" "${pick_base_url}" "${pick_key_env}"
        fi
        return 0
    fi

    # Local path — use curated.yaml
    local pick_json
    pick_json=$(pick_from_curated "${role}" "${want_vision}" "${prefer_free}")
    local pick_type
    pick_type=$(echo "${pick_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('type',''))" 2>/dev/null || echo "")

    if [ -z "${pick_type}" ]; then
        echo "✗ No curated pick found for role=${role} vision=${want_vision} free=${prefer_free}"
        echo "  Check: ~/.config/turbofit/curated.yaml"
        return 1
    fi

    if [ "${pick_type}" = "local" ]; then
        local pick_alias
        pick_alias=$(echo "${pick_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('alias',''))" 2>/dev/null || echo "")
        local pick_reason
        pick_reason=$(echo "${pick_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('reason',''))" 2>/dev/null || echo "")
        echo "→ Auto-pick for ${role} (LOCAL): ${pick_alias}"
        echo "  ${pick_reason}"
        echo ""

        if [ "${role}" = "main" ]; then
            serve_main "${pick_alias}"
        else
            serve_aux "${pick_alias}"
        fi
    else
        # API path
        local pick_provider pick_model_id pick_alias
        pick_provider=$(echo "${pick_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('provider',''))" 2>/dev/null || echo "")
        pick_model_id=$(echo "${pick_json}"  | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('model_id',''))"  2>/dev/null || echo "")
        pick_alias=$(echo "${pick_json}"     | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('alias',''))"   2>/dev/null || echo "")
        local pick_reason
        pick_reason=$(echo "${pick_json}"    | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('reason',''))"   2>/dev/null || echo "")

        local base_url="${API_BASE_URL[${pick_provider:-unknown}]:-https://openrouter.ai/api/v1}"
        local key_env="${API_KEY_ENV[${pick_provider:-unknown}]:-OPENROUTER_API_KEY}"

        echo "→ Auto-pick for ${role} (API): ${pick_alias}"
        echo "  Provider: ${pick_provider}  Model: ${pick_model_id}"
        echo "  ${pick_reason}"
        echo ""

        if [ "${role}" = "main" ]; then
            wire_hermes_api_main "${pick_model_id}" "${base_url}" "${key_env}"
        else
            wire_hermes_api_aux "${pick_model_id}" "${base_url}" "${key_env}"
        fi
    fi
}

serve_downscale() {
    # Probes current VRAM and either:
    #   - warns that everything is fine (no change)
    #   - shrinks ctx on the running main alias
    #   - stops aux to free VRAM
    #   - swaps to a smaller-tier main
    #   - offloads experts (MoE)
    local current_main
    current_main=$(python3 -c "
import yaml
with open('${HERMES_CONFIG}') as f: cfg = yaml.safe_load(f) or {}
print(cfg.get('model', {}).get('default', '') or '')
" 2>/dev/null || echo "")

    if [ -z "${current_main}" ]; then
        echo "✗ No main model set in ${HERMES_CONFIG}"
        return 1
    fi

    local vram_json
    vram_json=$(probe_vram)
    local free_gb
    free_gb=$(echo "${vram_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('free_GB','?'))" 2>/dev/null || echo "?")

    echo "Current main: ${current_main}"
    echo "Free VRAM:    ${free_gb} GB"
    echo ""

    # Find running aux daemons by scanning systemd services + catalog role
    local aux_aliases=()
    while IFS= read -r svc; do
        local alias
        alias=$(echo "$svc" | sed 's/turbofit-//; s/\.service//')
        [ -z "${alias}" ] && continue
        # Skip the main model
        [ "${alias}" = "${current_main}" ] && continue
        # Check if this alias has role: aux in the catalog
        local role
        role=$(python3 -c "
import yaml
with open('${CATALOG}') as f: cfg = yaml.safe_load(f) or {}
print(cfg.get('models', {}).get('${alias}', {}).get('role', ''))
" 2>/dev/null || echo "")
        if [ "${role}" = "aux" ]; then
            aux_aliases+=("${alias}")
        fi
    done < <(systemctl --user list-units --all --no-legend 2>/dev/null | grep -o 'turbofit-[^ ]*\.service' | sort -u)

    # Also check PID-file managed aux servers
    if [ -d "${TURBOFIT_ROOT}/pid" ]; then
        for pid_file in "${TURBOFIT_ROOT}/pid"/*; do
            [ -f "${pid_file}" ] || continue
            local a; a=$(basename "${pid_file}")
            [ "${a}" = "${current_main}" ] && continue
            # Check if already in list
            local skip=0
            for existing in "${aux_aliases[@]:-}"; do
                [ "${existing}" = "${a}" ] && skip=1 && break
            done
            [ "$skip" -eq 0 ] && aux_aliases+=("${a}")
        done
    fi

    # Heuristic ladder (simplified — full ladder in serve auto):
    if [ "${free_gb}" != "?" ] && awk "BEGIN{exit !(${free_gb} < 4)}"; then
        echo "⚠ Critical VRAM (<4GB). Consider API-only mode."
        echo "  Run: serve auto main --api --free && serve auto aux --free"
        echo "  Free option: DeepSeek V4 Pro (NIM) + Kimi K2.6 — zero cost, strong performance."
        return 0
    fi
    if [ "${free_gb}" != "?" ] && awk "BEGIN{exit !(${free_gb} < 8)}"; then
        echo "⚠ Tight VRAM (<8GB). Stop aux, shrink main ctx to 64K."
        # stop all aux models
        for a in "${aux_aliases[@]:-}"; do
            [ -n "${a}" ] && stop_server "${a}"
        done
        # rewrite catalog ctx to 65536 and restart main
        python3 - "${current_main}" <<'PYEOF'
import sys, yaml, os
alias = sys.argv[1]
p = os.environ.get("TURBOFIT_CATALOG", os.path.expanduser("~/.config/turbofit/models.yaml"))
with open(p) as f: cfg = yaml.safe_load(f) or {}
if alias in cfg.get("models", {}):
    cfg["models"][alias]["ctx"] = 65536
    with open(p, "w") as f: yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
        stop_server "${current_main}"
        launch_server "${current_main}"
        return $?
    fi
    if [ "${free_gb}" != "?" ] && awk "BEGIN{exit !(${free_gb} < 14)}"; then
        echo "⚠ Marginal VRAM (<14GB). Stop aux."
        for a in "${aux_aliases[@]:-}"; do
            [ -n "${a}" ] && stop_server "${a}"
        done
        return 0
    fi
    echo "✓ VRAM healthy — no downscale needed."
}

# ─────────────────────────────────────────────────────────────────────────────
# Hermes-Agent config
# ─────────────────────────────────────────────────────────────────────────────

set_hermes_main() {
    local model_name="$1"
    local base_url="$2"
    python3 - <<PYEOF
import yaml, os
cfg_path = "${HERMES_CONFIG}"
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("model", {})
cfg["model"]["default"] = "${model_name}"
cfg["model"]["base_url"] = "${base_url}"
cfg["model"]["api_key"] = "not-needed"
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Hermes main: ${model_name} @ ${base_url}"
}

set_hermes_aux() {
    local model_name="$1"
    local base_url="$2"
    local tasks=(vision web_extract compression session_search skills_hub approval mcp title_generation curator)
    python3 - <<PYEOF
import yaml, os
cfg_path = "${HERMES_CONFIG}"
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("auxiliary", {})
tasks = ${tasks[@]@Q}
for task in tasks:
    cfg["auxiliary"].setdefault(task, {})
    cfg["auxiliary"][task]["provider"] = "custom:local"
    cfg["auxiliary"][task]["base_url"] = "${base_url}"
    cfg["auxiliary"][task]["api_key"] = "not-needed"
    cfg["auxiliary"][task]["model"] = "${model_name}"
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Hermes aux: ${model_name} @ ${base_url} (${#tasks[@]} tasks)"
}

