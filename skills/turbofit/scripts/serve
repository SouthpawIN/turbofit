nvidia_nim_list() {
    [ -f "${NVIDIA_NIM_FILE}" ] || write_nvidia_nim_list
    python3 - <<'PYEOF'
import yaml, os
with open(os.environ.get("TURBOFIT_NIM_FILE", os.path.expanduser("~/.local/share/turbofit/nvidia-nim-curated.yaml"))) as f:
    cfg = yaml.safe_load(f)
print(f"Provider: {cfg['provider']}  base_url: {cfg['base_url']}")
print(f"All 5 models have FREE endpoints on build.nvidia.com (NVIDIA_API_KEY, ~1000 RPM at signup)")
print("")
print(f"{'Rank':<5} {'Model':<22} {'Vision':<7} {'$/in':<8} {'$/out':<8} API ID")
print("-" * 100)
for m in cfg['models']:
    vis = "👁 yes" if m['has_vision'] else "  no"
    pi = "FREE" if m.get('is_free') else f"${m['price_input']:.2f}"
    po = "FREE" if m.get('is_free') else f"${m['price_output']:.2f}"
    print(f"{m['rank']:<5} {m['name']:<22} {vis:<7} {pi:<8} {po:<8} {m['api_id']}")
PYEOF
}

nvidia_nim_use() {
    local rank_or_id="$1"
    local role="${2:-main}"
    [ -f "${NVIDIA_NIM_FILE}" ] || write_nvidia_nim_list
    python3 - "${rank_or_id}" "${role}" "${HERMES_CONFIG}" <<'PYEOF'
import sys, os, yaml
target, role, cfg_path = sys.argv[1], sys.argv[2], sys.argv[3]
with open(os.environ.get("TURBOFIT_NIM_FILE", os.path.expanduser("~/.local/share/turbofit/nvidia-nim-curated.yaml"))) as f:
    cfg = yaml.safe_load(f)
m = next((x for x in cfg['models'] if x['rank'] == int(target) or x['api_id'] == target), None)
if not m:
    print(f"Unknown rank/id: {target}"); sys.exit(1)
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg2 = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg2.setdefault("model", {})
cfg2["model"]["default"] = m['api_id']
cfg2["model"]["base_url"] = "https://integrate.api.nvidia.com/v1"
cfg2["model"]["api_key"] = "${NVIDIA_API_KEY}"
cfg2["model"]["context_length"] = cfg.get("context_length", 1000000)
if role == "aux":
    cfg2.setdefault("auxiliary", {})
    for task in ("vision","web_extract","compression","session_search","skills_hub","approval","mcp","title_generation","curator"):
        cfg2["auxiliary"].setdefault(task, {})
        cfg2["auxiliary"][task]["provider"] = "openai"
        cfg2["auxiliary"][task]["base_url"] = "https://integrate.api.nvidia.com/v1"
        cfg2["auxiliary"][task]["api_key"] = "${NVIDIA_API_KEY}"
        cfg2["auxiliary"][task]["model"] = m['api_id']
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg2, f, default_flow_style=False, sort_keys=False)
print(f"✓ Hermes {role}: {m['name']} ({m['api_id']})")
PYEOF
}

# ─────────────────────────────────────────────────────────────────────────────
# Catalog — extended schema
# ─────────────────────────────────────────────────────────────────────────────

next_port() {
    local used=()
    [ -f "${CATALOG}" ] && used+=($(grep -oE "port: [0-9]+" "${CATALOG}" 2>/dev/null | grep -oE "[0-9]+" || true))
    local port=8080
    while printf "%s\n" "${used[@]}" | grep -qx "${port}" 2>/dev/null; do
        port=$((port + 1))
    done
    echo "${port}"
}

register_alias() {
    local alias="$1"; local path="$2"
    local launcher="llama-cpp"; local port=""
    shift 2
    while [ $# -gt 0 ]; do
        case "$1" in
            --launcher) launcher="$2"; shift 2 ;;
            --port)     port="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    if [ -z "${alias}" ] || [ -z "${path}" ]; then
        echo "Usage: name <alias> <path-or-hf-repo> [--launcher llama-cpp|ollama|vllm|sglang] [--port N]"
        return 1
    fi
    [ -z "${port:-}" ] && port=$(next_port)
    python3 - <<PYEOF
import yaml, os
cfg_path = "${CATALOG}"
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path) if os.path.exists(cfg_path) else open(cfg_path, "w") as f:
    cfg = yaml.safe_load(f) if os.path.getsize(cfg_path) > 0 else {}
cfg.setdefault("models", {})
cfg["models"]["${alias}"] = {
    "launcher": "${launcher}",
    "path": "${path}",
    "port": ${port},
    "ctx": 65536,
}
with open(cfg_path, "w") as f:
    yaml.safe_dump(cfg, f, default_flow_style=False, sort_keys=False)
PYEOF
    echo "✓ Registered '${alias}' → ${path} (launcher=${launcher}) on :${port}"
}

list_catalog() {
    if [ ! -f "${CATALOG}" ]; then
        echo "Catalog empty. Use 'name <alias> <path>' to register a model."
        return
    fi
    python3 - <<'PYEOF'
import yaml, os
catalog = os.environ.get("TURBOFIT_CATALOG", os.path.expanduser("~/.config/turbofit/models.yaml"))
with open(catalog) as f:
    cfg = yaml.safe_load(f) or {}
models = cfg.get("models", {})
if not models:
    print("Catalog empty.")
else:
    print(f"{'Alias':<30} {'Tier':<5} {'Feat':<5} {'GPU':<4} {'Port':<6} {'Ctx':<7} {'Tok/s':<6} {'Launcher':<11} Description")
    print("-" * 140)
    # Sort: featured first, then by tier rank, then by name
    tier_rank = {"s":0,"sf":1,"sd":2,"f":3,"c":4}
    def sort_key(item):
        a, m = item
        return (0 if m.get("featured") else 1,
                tier_rank.get(m.get("tier","c"), 9),
                a)
    for alias, info in sorted(models.items(), key=sort_key):
        feat = "⭐" if info.get("featured") else "  "
        gpu = str(info.get("gpu","-"))
        tok = info.get("tok_s_target", "")
        desc = (info.get("description","") or "").replace("\n"," ")[:60]
        print(f"{alias:<30} {(info.get('tier','-')):<5} {feat:<5} {gpu:<4} {info.get('port','?'):<6} {info.get('ctx','?'):<7} {tok!s:<6} {(info.get('launcher','llama-cpp')):<11} {desc}")
PYEOF
}

# ─────────────────────────────────────────────────────────────────────────────
# High-level: launch + set as main/aux + start UI
# ─────────────────────────────────────────────────────────────────────────────

start_ui() {
    local ui="${1:-tui}"
    case "${ui}" in
        tui)       exec hermes --tui ;;
        dashboard) exec hermes dashboard ;;
        desktop)   exec hermes desktop ;;
        gateway)   exec hermes gateway run ;;
        herm|herm_main|herm_aux)
            exec herm
            ;;
        *)
            echo "Unknown UI: ${ui}"
            echo "  Supported: tui, dashboard, desktop, gateway, herm"
            return 1
            ;;
    esac
}

serve_main() {
    local alias="$1"
    local ui="${UI:-tui}"
    # Check if a systemd daemon is already running for this alias
    if systemctl --user is-active "turbofit-${alias}.service" >/dev/null 2>&1; then
        local port
        port=$(systemctl --user cat "turbofit-${alias}.service" 2>/dev/null | grep '^ExecStart=' | grep -oE '[0-9]+' | head -1)
        echo "✓ ${alias} already running as systemd daemon on :${port}"
        set_hermes_main "${alias}" "http://127.0.0.1:${port}/v1"
        start_ui "${ui}"
        return 0
    fi
    # Check if a PID-file managed server is already running
    if [ -f "${TURBOFIT_ROOT}/pid/${alias}" ] && kill -0 "$(cat "${TURBOFIT_ROOT}/pid/${alias}")" 2>/dev/null; then
        local port
        port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
        echo "✓ ${alias} already running (pid $(cat "${TURBOFIT_ROOT}/pid/${alias}")) on :${port}"
        set_hermes_main "${alias}" "http://127.0.0.1:${port}/v1"
        start_ui "${ui}"
        return 0
    fi
    launch_server "${alias}" || return 1
    local port
    port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
    set_hermes_main "${alias}" "http://127.0.0.1:${port}/v1"
    start_ui "${ui}"
}

serve_aux() {
    local alias="$1"
    local ui="${UI:-tui}"
    # Check if a systemd daemon is already running for this alias
    if systemctl --user is-active "turbofit-${alias}.service" >/dev/null 2>&1; then
        local port
        port=$(systemctl --user cat "turbofit-${alias}.service" 2>/dev/null | grep '^ExecStart=' | grep -oE '[0-9]+' | head -1)
        echo "✓ ${alias} already running as systemd daemon on :${port}"
        set_hermes_aux "${alias}" "http://127.0.0.1:${port}/v1"
        start_ui "${ui}"
        return 0
    fi
    # Check if a PID-file managed server is already running
    if [ -f "${TURBOFIT_ROOT}/pid/${alias}" ] && kill -0 "$(cat "${TURBOFIT_ROOT}/pid/${alias}")" 2>/dev/null; then
        local port
        port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
        echo "✓ ${alias} already running (pid $(cat "${TURBOFIT_ROOT}/pid/${alias}")) on :${port}"
        set_hermes_aux "${alias}" "http://127.0.0.1:${port}/v1"
        start_ui "${ui}"
        return 0
    fi
    launch_server "${alias}" || return 1
    local port
    port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
    set_hermes_aux "${alias}" "http://127.0.0.1:${port}/v1"
    start_ui "${ui}"
}

serve_herm() {
    local first="${1:-}"
    if [ "${first}" = "aux" ]; then
        shift
        local aux_alias="${1:-}"
        if [ -z "${aux_alias}" ]; then
            # No alias given — auto-pick aux, but use herm UI
            local pick_json
            pick_json=$(pick_from_curated "aux" "false" "false" 2>/dev/null)
            aux_alias=$(echo "${pick_json}" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(d.get('alias',''))" 2>/dev/null || echo "")
            if [ -z "${aux_alias}" ]; then
                echo "✗ No aux model found. Usage: serve herm [aux] [alias]"
                return 1
            fi
            echo "→ Auto-pick for aux: ${aux_alias}"
        fi
        UI="herm_aux" serve_aux "${aux_alias}"
    elif [ -n "${first}" ]; then
        UI="herm_main" serve_main "${first}"
    else
        # No args — auto-pick main and launch herm TUI
        local pick_json
        pick_json=$(pick_from_curated "main" "false" "false" 2>/dev/null)
        local main_alias
        main_alias=$(echo "${pick_json}" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(d.get('alias',''))" 2>/dev/null || echo "")
        if [ -z "${main_alias}" ]; then
            echo "✗ No main model found. Usage: serve herm [alias]"
            return 1
        fi
        echo "→ Auto-pick for main: ${main_alias}"
        UI="herm_main" serve_main "${main_alias}"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Daemon management — systemd user services with wake-on-ping proxy
# ─────────────────────────────────────────────────────────────────────────────
#
# Consolidates omni-va.service, llama-proxy-main.service, llama-darwin.service,
# model-rotation.service into turbofit-managed daemon services.
#
# Each daemon is a systemd user service named turbofit-<alias>.service that:
#   - Uses llama-proxy (wake-on-ping) to auto-spawn the backend on first request
#   - Idle-kills the backend after IDLE_KILL_SECS (default 1800 = 30 min)
#   - Auto-heals on crash (Restart=on-failure + clean-exit-0 pattern)
#   - Starts at boot (enabled in default.target.wants)
#   - Reads all flags from the catalog entry automatically
#
# Usage:
#   serve daemon install <alias>     Generate + enable systemd service for catalog model
#   serve daemon remove <alias>     Stop + disable + remove systemd service
#   serve daemon start <alias>      Start the daemon (proxy only — backend wakes on ping)
#   serve daemon stop <alias>       Stop the daemon (also kills backend, frees VRAM)
#   serve daemon restart <alias>    Stop + start
#   serve daemon status [alias]     Show status of one or all turbofit daemons
#   serve daemon list               List all turbofit-managed daemon services
#   serve daemon migrate <legacy>   Migrate a legacy service to turbofit daemon

DAEMON_UNIT_DIR="${HOME}/.config/systemd/user"
LLAMA_PROXY_BIN="${HOME}/bin/llama-proxy"

# Resolve the full extra args string for a daemon from the catalog entry
# This produces the value for LLAMA_SERVER_EXTRA_ARGS
daemon_extra_args() {
    local alias="$1"
    python3 - "$alias" <<'PYEOF'
import sys, os, yaml, json

alias = sys.argv[1]
catalog = os.environ.get("TURBOFIT_CATALOG", os.path.expanduser("~/.config/turbofit/models.yaml"))
if not os.path.exists(catalog):
    sys.exit(1)

with open(catalog) as f:
    cfg = yaml.safe_load(f) or {}
models = cfg.get("models", {})

# Resolve alias
m = models.get(alias)
if not m:
    for canonical, info in models.items():
        if alias in (info.get("aliases") or []):
            m = info; alias = canonical; break
if not m:
    sys.exit(1)

# Build extra args
args = []

# 1) Presets
preset_map = {
    "nextn": ["--spec-type", "nextn", "--draft-block-size", "3"],
    "nextn-tight": ["--spec-type", "nextn", "--draft-block-size", "2"],
    "draft-mtp": ["--spec-type", "draft-mtp"],
    "draft-mtp-tight": ["--spec-type", "draft-mtp", "--draft-block-size", "2"],
    "turbo4-kv": ["-ctk", "turbo4", "-ctv", "turbo4"],
    "turbo3-kv": ["-ctk", "turbo3", "-ctv", "turbo3"],
    "turbo2-kv": ["-ctk", "turbo2", "-ctv", "turbo2"],
    "q8-kv": ["-ctk", "q8_0", "-ctv", "q8_0"],
    "q4-kv": ["-ctk", "q4_0", "-ctv", "q4_0"],
    "no-mmap": ["--no-mmap"],
    "split-none": ["--split-mode", "none"],
    "mlock": ["--mlock"],
    "parallel-4": ["--parallel", "4"],
    "parallel-2": ["--parallel", "2"],
    "parallel-1": ["--parallel", "1"],
    "cpu-moe-2": ["--n-cpu-moe", "2"],
    "cpu-moe-4": ["--n-cpu-moe", "4"],
    "cpu-moe-8": ["--n-cpu-moe", "8"],
}

for p in (m.get("presets") or []):
    if p in preset_map:
        args.extend(preset_map[p])

# 2) Extra args
for a in (m.get("extra_args") or []):
    args.append(str(a))

# 3) GPU selection → --main-gpu
gpu = m.get("gpu")
if gpu is not None:
    args.extend(["--main-gpu", str(gpu)])

# 4) mmproj
if m.get("mmproj"):
    args.extend(["--mmproj", m["mmproj"]])

# 5) Context (enforce 64K floor)
ctx = m.get("ctx", 65536)
if ctx < 65536:
    ctx = 65536
args.extend(["-c", str(ctx)])

# 6) Flash attention
args.extend(["--flash-attn", "on"])

# 7) model-draft for spec decoding (if nextn/draft-mtp preset, use same GGUF)
presets = m.get("presets") or []
has_spec = any(p in presets for p in ["nextn", "nextn-tight", "draft-mtp", "draft-mtp-tight"])
if has_spec:
    model_path = m.get("path", "")
    args.extend(["--model-draft", model_path])
    # Note: --cpu-moe-draft and --mmproj-draft are not supported in the current
    # atomic fork. The draft model shares the same GGUF so cpu-moe applies
    # automatically if set on the main model.

# 9) Parallel override
if m.get("parallel"):
    args.extend(["--parallel", str(m["parallel"])])

# Print as single string (space-joined)
print(" ".join(args))
PYEOF
}

# Generate a systemd user service unit for a catalog alias
daemon_install() {
    local alias="$1"
    shift || true

    # Parse optional flags
    local idle_secs="${DAEMON_IDLE_SECS:-1800}"
    local startup_timeout="${DAEMON_STARTUP_TIMEOUT:-900}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --idle)      idle_secs="$2"; shift 2 ;;
            --timeout)   startup_timeout="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    # Resolve alias from catalog
    local info
    info=$(alias_info "${alias}" 2>/dev/null)
    [ -z "${info}" ] && { echo "✗ Unknown alias: ${alias}"; return 1; }

    local launcher path port ctx
    launcher=$(echo "${info}" | awk '{print $1}')
    path=$(echo "${info}"     | awk '{print $2}')
    port=$(echo "${info}"     | awk '{print $3}')
    ctx=$(echo "${info}"      | awk '{print $4}')

    # Only llama-cpp supports wake-on-ping proxy
    if [ "${launcher}" != "llama-cpp" ]; then
        echo "✗ Daemon mode only supports llama-cpp launcher (got: ${launcher})"
        return 1
    fi

    # Get full model info
    local catalog_json
    catalog_json=$(alias_full "${alias}" 2>/dev/null || true)
    local binary=""
    local gpu=0
    local description=""
    if [ -n "${catalog_json}" ]; then
        binary=$(echo "${catalog_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('binary','') or '')" 2>/dev/null || echo "")
        gpu=$(echo "${catalog_json}" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('gpu',0))" 2>/dev/null || echo "0")
        description=$(echo "${catalog_json}" | python3 -c "import sys,json; print((json.loads(sys.stdin.read()).get('description','') or '').replace(chr(10),' ')[:120])" 2>/dev/null || echo "")
    fi
    [ -z "${binary}" ] && binary="llama-server"

    # Resolve extra args from catalog
    local extra_args
    extra_args=$(daemon_extra_args "${alias}" 2>/dev/null || echo "")

    # Calculate proxy and backend ports
    local proxy_port="${port}"
    local backend_port=$((port + 1000))

    # Generate the service unit
    local unit_name="turbofit-${alias}.service"
    local unit_path="${DAEMON_UNIT_DIR}/${unit_name}"
    mkdir -p "${DAEMON_UNIT_DIR}"

    # Build LD_LIBRARY_PATH + LLAMA_LIB_DIR lines only if using custom binary
    local ld_line=""
    local lib_line=""
    if [ -n "${binary}" ] && [ "${binary}" != "llama-server" ]; then
        local lib_dir
        lib_dir=$(dirname "${binary}")
        ld_line="Environment=\"LD_LIBRARY_PATH=${lib_dir}\""
        lib_line="Environment=\"LLAMA_LIB_DIR=${lib_dir}\""
    fi

    cat > "${unit_path}" <<EOF
[Unit]
Description=turbofit daemon — ${alias}${description:+ (${description})}
Documentation=https://github.com/SouthpawIN/turbofit
After=network.target

[Service]
# turbofit-managed daemon — wake-on-ping proxy + auto-heal
# Proxy listens on :${proxy_port}, spawns backend on :${backend_port} (GPU ${gpu}) on first request
# Idle-kills backend after ${idle_secs}s of no traffic (frees VRAM)
# Auto-heals on crash (Restart=on-failure), clean stops stay down (exit 0)

# Binary + library paths
Environment="LLAMA_SERVER=${binary}"
${ld_line}
${lib_line}

# Extra args resolved from catalog entry
Environment="LLAMA_SERVER_EXTRA_ARGS=${extra_args}"

# Idle timeout (seconds of no traffic before backend is killed)
Environment="IDLE_KILL_SECS=${idle_secs}"

# Startup timeout (max seconds to wait for backend to become healthy)
Environment="STARTUP_TIMEOUT=${startup_timeout}"

# ExecStart: proxy <listen_port> <backend_port> <gpu_id> <model_path>
ExecStart=${LLAMA_PROXY_BIN} ${proxy_port} ${backend_port} ${gpu} ${path}

# Auto-heal policy: restart ONLY on actual failures (non-zero exit, signal, OOM)
# NOT on clean stops. Combined with proxy SIGTERM/SIGINT handler (exit 0):
#   crash (segfault, OOM)     -> systemd restarts
#   systemctl stop             -> exits 0, no restart
#   boot                       -> starts because [Install] enabled
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
KillMode=mixed

StandardOutput=append:${TURBOFIT_ROOT}/logs/daemon-${alias}.log
StandardError=append:${TURBOFIT_ROOT}/logs/daemon-${alias}.log

[Install]
WantedBy=default.target
EOF

    # Reload systemd
    systemctl --user daemon-reload

    # Enable + start
    systemctl --user enable "${unit_name}"
    systemctl --user start "${unit_name}"

    echo "✓ Daemon installed: ${alias}"
    echo ""
    echo "  Service:  ${unit_name}"
    echo "  Proxy:    :${proxy_port} (wake-on-ping)"
    echo "  Backend:  :${backend_port} (GPU ${gpu})"
    echo "  Model:    ${path}"
    echo "  Binary:   ${binary}"
    echo "  Extra:    ${extra_args}"
    echo "  Idle:     ${idle_secs}s"
    echo "  Logs:     ${TURBOFIT_ROOT}/logs/daemon-${alias}.log"
    echo ""
    echo "  Commands:"
    echo "    serve daemon status ${alias}"
    echo "    serve daemon stop ${alias}"
    echo "    serve daemon remove ${alias}"
}

# Remove a turbofit-managed daemon
daemon_remove() {
    local alias="$1"
    local unit_name="turbofit-${alias}.service"
    local unit_path="${DAEMON_UNIT_DIR}/${unit_name}"

    if [ ! -f "${unit_path}" ]; then
        echo "✗ No turbofit daemon for: ${alias}"
        echo "  Looking for: ${unit_path}"
        # Check if there's a legacy service to clean up
        echo ""
        echo "  Legacy services to consider removing:"
        for svc in omni-va llama-darwin llama-proxy-main model-rotation; do
            if systemctl --user list-unit-files "${svc}.service" 2>/dev/null | grep -q "enabled\|disabled"; then
                echo "    ${svc}.service ($(systemctl --user is-active "${svc}.service" 2>/dev/null || echo "unknown"))"
            fi
        done
        return 1
    fi

    # Stop + disable
    systemctl --user stop "${unit_name}" 2>/dev/null || true
    systemctl --user disable "${unit_name}" 2>/dev/null || true

    # Remove the unit file
    rm -f "${unit_path}"
    systemctl --user daemon-reload

    echo "✓ Daemon removed: ${alias}"
}

# Start/stop/restart a daemon
daemon_start() {
    local alias="$1"
    local unit_name="turbofit-${alias}.service"
    if [ ! -f "${DAEMON_UNIT_DIR}/${unit_name}" ]; then
        echo "✗ No daemon for ${alias}. Run: serve daemon install ${alias}"
        return 1
    fi
    systemctl --user start "${unit_name}"
    echo "✓ Daemon started: ${alias}"
}

daemon_stop() {
    local alias="$1"
    local unit_name="turbofit-${alias}.service"
    if [ ! -f "${DAEMON_UNIT_DIR}/${unit_name}" ]; then
        echo "✗ No daemon for ${alias}"
        return 1
    fi
    systemctl --user stop "${unit_name}"
    echo "✓ Daemon stopped: ${alias} (backend killed, VRAM freed)"
}

daemon_restart() {
    local alias="$1"
    local unit_name="turbofit-${alias}.service"
    if [ ! -f "${DAEMON_UNIT_DIR}/${unit_name}" ]; then
        echo "✗ No daemon for ${alias}"
        return 1
    fi
    systemctl --user restart "${unit_name}"
    echo "✓ Daemon restarted: ${alias}"
}

# Show daemon status
daemon_status() {
    local alias="${1:-}"
    if [ -n "${alias}" ]; then
        local unit_name="turbofit-${alias}.service"
        if [ ! -f "${DAEMON_UNIT_DIR}/${unit_name}" ]; then
            echo "✗ No daemon for ${alias}"
            return 1
        fi
        systemctl --user status "${unit_name}" 2>/dev/null || true
    else
        # Show all turbofit daemons
        echo "turbofit-managed daemons:"
        echo ""
        for unit_path in "${DAEMON_UNIT_DIR}"/turbofit-*.service; do
            [ -f "${unit_path}" ] || continue
            local unit_name
            unit_name=$(basename "${unit_path}")
            local dalias="${unit_name#turbofit-}"
            dalias="${dalias%.service}"
            local active
            active=$(systemctl --user is-active "${unit_name}" 2>/dev/null || echo "unknown")
            local enabled
            enabled=$(systemctl --user is-enabled "${unit_name}" 2>/dev/null || echo "unknown")
            local proxy_port
            proxy_port=$(grep -oP 'ExecStart=.*?\s+\K\d+' "${unit_path}" | head -1 || echo "?")
            printf "  %-35s  %-10s  %-8s  :%s\n" "${dalias}" "${active}" "${enabled}" "${proxy_port}"
        done
        if [ -z "$(ls "${DAEMON_UNIT_DIR}"/turbofit-*.service 2>/dev/null)" ]; then
            echo "  (none installed)"
        fi
    fi
}

# List all turbofit daemons
daemon_list() {
    daemon_status
}

# Migrate a legacy service to a turbofit daemon
daemon_migrate() {
    local service_name="$1"
    local alias="$2"

    if [ -z "${alias}" ]; then
        # Try to infer alias from service name
        case "${service_name}" in
            omni-va)          alias="carnice-apex" ;;
            llama-darwin)     alias="darwin-28b-reason" ;;
            llama-proxy-main) alias="carnice-apex-compact" ;;
            *)                echo "✗ Specify target alias: serve daemon migrate <legacy-service> <alias>"; return 1 ;;
        esac
    fi

    # Stop + disable the legacy service
    echo "→ Migrating ${service_name}.service → turbofit-${alias}.service"
    systemctl --user stop "${service_name}.service" 2>/dev/null || true
    systemctl --user disable "${service_name}.service" 2>/dev/null || true

    # Install the turbofit daemon
    daemon_install "${alias}"

    echo ""
    echo "  Legacy service ${service_name}.service is stopped+disabled."
    echo "  To fully remove it: rm ${DAEMON_UNIT_DIR}/${service_name}.service && systemctl --user daemon-reload"
}

# ─────────────────────────────────────────────────────────────────────────────
# Fetch model from HuggingFace (from llama-launch)
# ─────────────────────────────────────────────────────────────────────────────

fetch_model() {
    local alias="$1"
    local repo
    repo=$(python3 - "$alias" "$CATALOG" <<'PYEOF'
import sys, yaml
alias, catalog = sys.argv[1], sys.argv[2]
with open(catalog) as f:
    cfg = yaml.safe_load(f) or {}
m = cfg.get("models", {}).get(alias)
if not m or not m.get("hf_repo"):
    print("")
    sys.exit(1)
print(m["hf_repo"])
PYEOF
)
    if [ -z "${repo}" ]; then
        echo "No hf_repo field. Add 'hf_repo: org/repo' to catalog entry for ${alias}"
        return 1
    fi
    echo "Downloading ${alias} from huggingface.co/${repo} (Q4_K_M only)..."
    local dest_dir
    dest_dir=$(dirname "$(alias_info "${alias}" 2>/dev/null | awk '{print $2}')")
    mkdir -p "${dest_dir}"
    hf download "${repo}" --include="*Q4_K_M*" --local-dir "${dest_dir}"
    echo "Done."
}

# ─────────────────────────────────────────────────────────────────────────────
# Benchmark model with lm-eval-harness (from llama-launch)
# ─────────────────────────────────────────────────────────────────────────────

bench_model() {
    local alias="$1"
    alias_info "${alias}" 2>/dev/null >/dev/null || { echo "Unknown alias: ${alias}"; return 1; }
    local port
    port=$(cat "${TURBOFIT_ROOT}/port/${alias}" 2>/dev/null || echo 8080)
    if ! curl -sf "http://127.0.0.1:${port}/v1/models" >/dev/null 2>&1; then
        launch_server "${alias}" || return 1
    fi
    echo "Benchmarking ${alias} (mmlu, gsm8k)..."
    lm_eval --model local-completions \
        --model_args "model=${alias},base_url=http://127.0.0.1:${port}/v1" \
        --tasks mmlu,gsm8k --limit 100 2>&1 | tail -20
}

# ─────────────────────────────────────────────────────────────────────────────
# mmproj management: verify, find, download, set correct mmproj per model
# ─────────────────────────────────────────────────────────────────────────────

# n_embd mapping by model family
# Qwen3.6-27B dense (Darwin, Prism, Qwopus, Qwable, Carwin): n_embd=5120
# Qwen3.6-35B-A3B MoE (Carnice, Darwin Apex): n_embd=2048
# Qwen2.5-Omni-3B: n_embd=2048

manage_mmproj() {
    local action="${1:-check}"
    local alias="${2:-}"

    case "${action}" in
        check)
            echo "Checking mmproj for all vision models..."
            python3 - "$CATALOG" <<'PYEOF'
import sys, os, yaml

catalog_path = sys.argv[1]
with open(catalog_path) as f:
    cfg = yaml.safe_load(f) or {}

models = cfg.get("models", {})
issues = []

for alias, m in sorted(models.items()):
    vision = m.get("vision", False)
    mmproj = m.get("mmproj", "")
    
    if not vision:
        continue
    
    if not mmproj:
        issues.append(f"  ❌ {alias}: vision=true but NO mmproj set")
        continue
    
    if not os.path.exists(mmproj):
        issues.append(f"  ❌ {alias}: mmproj MISSING — {mmproj}")
        continue
    
    # Check if it's a symlink and verify target
    if os.path.islink(mmproj):
        target = os.readlink(mmproj)
        if not os.path.exists(target):
            issues.append(f"  ❌ {alias}: mmproj BROKEN SYMLINK — {mmproj} → {target}")
            continue
    
    # Determine n_embd from model path
    path = m.get("path", "")
    n_embd_model = "?"
    n_embd_mmproj = "?"
    
    # Try to get n_embd from running model
    port = m.get("port", 0)
    if port:
        try:
            import httpx
            resp = httpx.get(f"http://127.0.0.1:{port}/v1/models", timeout=2)
            if resp.status_code == 200:
                data = resp.json()
                n_embd_model = data["data"][0]["meta"].get("n_embd", "?")
        except:
            pass
    
    # Infer n_embd from mmproj filename
    if "mmproj-BF16" in mmproj or "mmproj-F16" in mmproj:
        n_embd_mmproj = "2048 (MoE)"
    elif "mmproj-F32" in mmproj:
        # Could be 5120 (27B) or 2048 (Omni-3B) — check path
        if "Omni" in mmproj:
            n_embd_mmproj = "2048 (Omni-3B)"
        else:
            n_embd_mmproj = "5120 (27B dense)"
    elif "Omni-3B" in mmproj:
        n_embd_mmproj = "2048 (Omni-3B)"
    else:
        n_embd_mmproj = "unknown"
    
    # Check for mismatch
    match = "✅" if (n_embd_model == "?" or n_embd_mmproj == "?" or str(n_embd_model) in n_embd_mmproj) else "⚠️ MISMATCH"
    
    if "MISMATCH" in match:
        issues.append(f"  ⚠️ {alias}: n_embd MISMATCH — model={n_embd_model}, mmproj={n_embd_mmproj}")
    
    size = os.path.getsize(mmproj) if os.path.exists(mmproj) else 0
    size_mb = size // (1024*1024)
    link = " (symlink)" if os.path.islink(mmproj) else ""
    print(f"  {match} {alias}: n_embd={n_embd_model} mmproj={n_embd_mmproj} ({size_mb}MB){link}")
    print(f"       {mmproj}")

if issues:
    print("\nISSUES FOUND:")
    for issue in issues:
        print(issue)
    print(f"\n{len(issues)} issue(s) found. Run 'serve mmproj fix <alias>' to resolve.")
else:
    print("\n✅ All mmproj files verified.")
PYEOF
            ;;
        fix)
            if [ -z "$alias" ]; then
                echo "Usage: serve mmproj fix <alias>"
                echo "  Finds, downloads, and sets the correct mmproj for a model."
                echo ""
                echo "  If the model's HF repo has an mmproj, it downloads it."
                echo "  If not, it finds a compatible mmproj from the same model family."
                exit 1
            fi
            
            local model_path hf_repo current_mmproj
            model_path=$(python3 -c "
import yaml, os
with open('$CATALOG') as f: cfg = yaml.safe_load(f)
m = cfg.get('models', {}).get('$alias', {})
print(m.get('path', ''))
" 2>/dev/null)
            hf_repo=$(python3 -c "
import yaml, os
with open('$CATALOG') as f: cfg = yaml.safe_load(f)
m = cfg.get('models', {}).get('$alias', {})
print(m.get('hf_repo', ''))
" 2>/dev/null)
            current_mmproj=$(python3 -c "
import yaml, os
with open('$CATALOG') as f: cfg = yaml.safe_load(f)
m = cfg.get('models', {}).get('$alias', {})
print(m.get('mmproj', ''))
" 2>/dev/null)
            
            if [ -z "$model_path" ]; then
                echo "❌ Model '$alias' not found in catalog."
                exit 1
            fi
            
            local model_dir
            model_dir=$(dirname "$model_path")
            
            echo "Model: $alias"
            echo "Path:  $model_path"
            echo "HF:    ${hf_repo:-not set}"
            echo "Current mmproj: ${current_mmproj:-none}"
            echo ""
            
            # Check if current mmproj exists and is valid
            if [ -n "$current_mmproj" ] && [ -f "$current_mmproj" ]; then
                echo "✅ mmproj exists at $current_mmproj"
                # Verify n_embd match
                echo "Run 'serve mmproj check' to verify n_embd compatibility."
                return 0
            fi
            
            # Try to download from HF repo
            if [ -n "$hf_repo" ]; then
                echo "Downloading mmproj from HF repo: $hf_repo"
                # Try common mmproj filenames
                for mmproj_name in "mmproj-F32.gguf" "mmproj-BF16.gguf" "mmproj-f16.gguf" "mmproj-model-f16.gguf"; do
                    echo "  Trying: $mmproj_name"
                    if hf download "$hf_repo" --include="$mmproj_name" --local-dir "$model_dir" 2>/dev/null; then
                        local new_mmproj="$model_dir/$mmproj_name"
                        if [ -f "$new_mmproj" ]; then
                            echo "  ✅ Downloaded: $new_mmproj"
                            # Update catalog
                            python3 -c "
import yaml
path = '$CATALOG'
with open(path) as f: cfg = yaml.safe_load(f)
cfg['models']['$alias']['mmproj'] = '$new_mmproj'
cfg['models']['$alias']['vision'] = True
with open(path, 'w') as f: yaml.dump(cfg, f, default_flow_style=False, sort_keys=False)
print(f'Updated catalog: mmproj set to $new_mmproj')
" 2>/dev/null
                            echo "✅ mmproj set permanently in catalog."
                            return 0
                        fi
                    fi
                done
                echo "  ⚠️ No mmproj found in HF repo."
            fi
            
            # Fallback: find compatible mmproj from same model family
            echo ""
            echo "Searching for compatible mmproj from same model family..."
            local model_base
            model_base=$(basename "$model_path")
            
            # Determine model family
            local n_embd_target
            if echo "$model_base" | grep -qi "35B\|A3B\|MoE\|Apex\|Carnice"; then
                n_embd_target="2048"
                echo "  Model family: MoE (n_embd=2048)"
            elif echo "$model_base" | grep -qi "Omni\|3B"; then
                n_embd_target="2048"
                echo "  Model family: Omni-3B (n_embd=2048)"
            else
                n_embd_target="5120"
                echo "  Model family: 27B dense (n_embd=5120)"
            fi
            
            # Search for existing mmproj files with matching n_embd
            local found_mmproj=""
            if [ "$n_embd_target" = "2048" ]; then
                # Look for mmproj-BF16 or mmproj-f16 (MoE)
                found_mmproj=$(find /home/sovthpaw/Models/ -name "mmproj-BF16.gguf" -o -name "mmproj-f16.gguf" 2>/dev/null | head -1)
            else
                # Look for mmproj-F32 (27B dense)
                found_mmproj=$(find /home/sovthpaw/Models/ -name "mmproj-F32.gguf" -not -path "*Omni*" 2>/dev/null | head -1)
            fi
            
            if [ -n "$found_mmproj" ]; then
                echo "  Found compatible mmproj: $found_mmproj"
                # Symlink it into the model dir
                local new_mmproj="$model_dir/mmproj-F32.gguf"
                if [ "$n_embd_target" = "2048" ]; then
                    new_mmproj="$model_dir/mmproj-BF16.gguf"
                fi
                ln -sf "$found_mmproj" "$new_mmproj"
                echo "  Symlinked: $new_mmproj → $found_mmproj"
                # Update catalog
                python3 -c "
import yaml
path = '$CATALOG'
with open(path) as f: cfg = yaml.safe_load(f)
cfg['models']['$alias']['mmproj'] = '$new_mmproj'
cfg['models']['$alias']['vision'] = True
with open(path, 'w') as f: yaml.dump(cfg, f, default_flow_style=False, sort_keys=False)
print(f'Updated catalog: mmproj set to $new_mmproj')
" 2>/dev/null
                echo "✅ mmproj set permanently in catalog."
                return 0
            else
                echo "  ❌ No compatible mmproj found on disk."
                echo ""
                echo "To fix manually:"
                echo "  1. Find the correct mmproj from the model's HF repo"
                echo "  2. Download it: hf download $hf_repo --include='mmproj*' --local-dir $model_dir"
                echo "  3. Set it: serve register $alias $model_path --mmproj <path>"
                return 1
            fi
            ;;
        *)
            echo "Usage: serve mmproj {check|fix <alias>}"
            echo ""
            echo "  check          Verify all vision models have correct mmproj"
            echo "  fix <alias>    Find/download/set correct mmproj for a model"
            ;;
    esac
}

# ─────────────────────────────────────────────────────────────────────────────
# Recommend: scan catalog, rank by Chris's criteria
# ─────────────────────────────────────────────────────────────────────────────

recommend_fit() {
    echo "Scanning catalog (ctx≥64K, tok/s≥25, Q4, vision preferred)..."
    python3 - "$CATALOG" <<'PYEOF'
import sys, yaml, os
cat_path = sys.argv[1]
with open(cat_path) as f:
    cfg = yaml.safe_load(f) or {}
models = cfg.get("models", {})

results = []
for alias, m in models.items():
    path = m.get("path", "")
    if not os.path.exists(path):
        continue
    ctx    = m.get("ctx", 0)
    tok_s  = m.get("tok_s_target", 0)
    tier   = m.get("tier", "c")
    vision = m.get("vision", False)
    size   = m.get("size_gb", 99)
    if ctx < 65536: continue
    if tok_s < 25: continue
    tier_score = {"s": 5, "sf": 4, "sd": 3, "f": 2, "c": 1}.get(tier, 1)
    score = tier_score * 10 + (10 if vision else 0) + (tok_s // 25)
    results.append((score, alias, tier, tok_s, vision, size))

results.sort(key=lambda x: -x[0])
print(f"\n{'RANK':<5} {'ALIAS':<35} {'TIER':<4} {'tok/s':>6} {'VISION':>6} {'SIZE':>6} {'SCORE':>5}")
print("-" * 80)
for i, (score, alias, tier, tok_s, vision, size) in enumerate(results[:20], 1):
    print(f"{i:<5} {alias:<35} {tier:<4} {tok_s:>6} {' 👁' if vision else '':>6} {size:>5.0f}GB {score:>5}")
print(f"\n{len(results)} models match (ctx≥64K, tok/s≥25). Ranked by tier + vision + speed.")
PYEOF
}

# ─────────────────────────────────────────────────────────────────────────────
# Usage
# ─────────────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
turbofit serve v5 — opinionated unified backend (turbofit v5.0.0)

INSTALL / UPDATE
  serve install                            Install llama.cpp from source
  serve install <launcher>                 Install one launcher: llama-cpp, ollama, vllm, sglang
  serve update                             Update llama.cpp
  serve update <launcher|all>              Update a specific launcher or all
  serve check                              Show version status for all installed

FIT CHECK
  serve fit <model> [ctx]                  Run llmfit fit check (default ctx=65536)
  serve vram                               Probe live GPU VRAM (JSON)
  serve recommend                          Scan all catalog entries, rank by fit (ctx≥64K, tok/s≥25, Q4, vision)

CATALOG
  serve register <alias> <path>            Register model (launcher=llama-cpp)
           [--launcher llama-cpp|ollama|vllm|sglang]
           [--port N]
  serve catalog                            Show registered aliases (featured first, tier-ordered)

LAUNCH
  serve <alias>                            Launch (detached, shows backend/port/logs)
  serve string <alias>                     Print launch string (no launch)
  serve stop <alias>                       Stop a running server
  serve stop-all                           Stop everything
  serve list                               List running servers + rogue llama-servers on any port

OPINIONATED AUTO (turbofit v5.1 — hardware-aware, API-aware)
  serve auto main [--vision] [--api] [--free] [--ui ...]   Pick best main (auto-detects GPU, suggests API if needed)
  serve auto aux [--vision] [--api] [--free] [--ui ...]    Pick best aux
  serve downscale                          Probe VRAM, shrink ctx / drop aux / swap tier if needed
  AUTO_CTX=131072 serve auto main          Override ctx target

  Hardware tiers (auto-detected):
    ≥24GB VRAM: Local main + local aux (full ladder)
    8-24GB VRAM: API main + local aux OR local main + API aux
    <8GB / no GPU: API main + API aux (free: DeepSeek V4 Pro + Kimi K2.6)

FETCH / BENCH (from llama-launch)
  serve fetch <alias>                      Download missing model from HF (uses hf_repo in catalog)
  serve bench <alias>                      Run lm-eval-harness benchmark (launches model first)

MMPROJ MANAGEMENT
  serve mmproj check                      Verify all vision models have correct mmproj (n_embd match)
  serve mmproj fix <alias>                 Find/download/set correct mmproj for a model

HERMES MODEL ROUTING
  serve main <alias> [--ui tui|dashboard|gateway|desktop|herm]
                                           Launch + set main + start UI
  serve aux  <alias> [--ui ...]            Launch + set aux + start UI
  serve herm <alias>                       Launch + main + herm TUI (herm handles hermes internally)
  serve herm aux <alias>                   Launch + aux + herm TUI

NVIDIA NIM API (curated, 5 models)
  serve api list                           Show the curated NVIDIA NIM list
  serve api use <rank|api_id> [main|aux]   Wire a NIM model into Hermes config

DAEMON (systemd services with wake-on-ping proxy)
  serve daemon install <alias> [--idle N]  Generate + enable systemd service for catalog model
  serve daemon remove <alias>             Stop + disable + remove daemon service
  serve daemon start <alias>              Start daemon (proxy only — backend wakes on ping)
  serve daemon stop <alias>               Stop daemon (also kills backend, frees VRAM)
  serve daemon restart <alias>            Stop + start
  serve daemon status [alias]             Show status of one or all turbofit daemons
  serve daemon list                       List all turbofit-managed daemon services
  serve daemon migrate <legacy> [alias]   Migrate a legacy service to turbofit daemon

SHELL ALIASES (installed to ~/.bashrc):
  name <alias> <path> [--launcher ...]     Register a model alias
  serve <alias>                            Launch + show backend/port/logs
  serve auto main                          Pick best main + launch (opinionated)
  serve downscale                          Adapt running fleet to current VRAM

CATALOG SCHEMA (extended in v5):
  launcher:    llama-cpp | ollama | vllm | sglang
  path:        absolute path to GGUF / HF repo
  port:        integer (auto-assigned if absent)
  ctx:         context window (64K floor enforced)
  gpu:         0 | 1 (single-GPU target)
  mmproj:      path to vision projector (optional)
  presets:     [nextn, draft-mtp, turbo4-kv, no-mmap, split-none]
  extra_args:  [list of raw llama-server flags]
  aliases:     [short, alt, ...]
  description: one-liner for `serve catalog`
  tags:        [free-form]
  tier:        s | sf | sd | f | c  (used by serve auto)
  featured:    true | false  (Garage top row)
  tok_s_target: integer  (measured throughput)
  vision:      true | false
  size_gb:     float
  hf_repo:     HF org/repo (for fetch)
  role:        main | aux | either  (default: aux)
EOF
}

# ─────────────────────────────────────────────────────────────────────────────
# Parse top-level flags
# ─────────────────────────────────────────────────────────────────────────────

UI=""
AUTO_CTX="${AUTO_CTX:-}"
gateway_flag=0
positional=()
while [ $# -gt 0 ]; do
    case "$1" in
        --ui) UI="$2"; shift 2 ;;
        --ui=*) UI="${1#--ui=}"; shift ;;
        --gateway|-gateway) gateway_flag=1; shift ;;
        --ctx) AUTO_CTX="$2"; shift 2 ;;
        --ctx=*) AUTO_CTX="${1#--ctx=}"; shift ;;
        *) positional+=("$1"); shift ;;
    esac
done
if [ "${gateway_flag}" = "1" ] && [ -z "${UI}" ]; then
    UI="gateway"
fi
set -- "${positional[@]+"${positional[@]}"}"

cmd="${1:-help}"
shift || true

case "${cmd}" in
    install)        install_launcher "${1:-llama-cpp}" ;;
    update)         update_all_launchers "${1:-llama-cpp}" ;;
    check)          check_llama_cpp ;;
    fit)            check_fit "$@" ;;
    vram)           probe_vram ;;
    string)
        info=$(alias_info "${1:-}" 2>/dev/null) || { echo "Usage: serve string <alias>"; exit 1; }
        generate_string "${1}"
        ;;
    stop)           stop_server "${1:-}" ;;
    stop-all)       stop_all ;;
    list|ls|ps)     list_running ;;
    catalog)        list_catalog ;;
    register|name)  register_alias "$@" ;;
    fetch)          fetch_model "${1:-}" ;;
    bench)
        case "${1:-run}" in
            run)      bench_model "${2:-}" ;;
            pipeline) shift; python3 "${TURBOFIT_SKILL_DIR}/scripts/benchmark-pipeline.py" "$@" ;;
            pull)
                echo "Pulling latest benchmark results from GitHub..."
                curl -sL "https://raw.githubusercontent.com/SouthpawIN/turbofit/main/skills/turbofit/references/benchmark-results.json" \
                    -o "${TURBOFIT_SKILL_DIR}/references/benchmark-results.json" 2>/dev/null
                if [ $? -eq 0 ]; then
                    echo "Done. Results:"
                    python3 -c "
import json
with open('${TURBOFIT_SKILL_DIR}/references/benchmark-results.json') as f:
    data = json.load(f)
print(f\"  Date: {data.get('date','?')}\")
print(f\"  GPU:  {data.get('gpu_name','?')}\")
print(f\"  CTX:  {data.get('ctx','?')}\")
print()
print(f\"{'Model':<30} {'tok/s':>8} {'Size':>8} {'MTP':>5} {'Vis':>5}\")
print('-'*60)
for r in sorted(data.get('results',[]), key=lambda x: x.get('tok_s',0), reverse=True):
    if r.get('status') == 'ok':
        print(f\"{r['name']:<30} {r['tok_s']:>8.1f} {r.get('size_gb',0):>7.1f}G {'Y' if r.get('has_mtp') else 'N':>5} {'Y' if r.get('has_vision') else 'N':>5}\")
"
                else
                    echo "Failed to download results"
                fi
                ;;
            *)  echo "Usage: serve bench {run <alias>|pipeline [--push]|pull}"; exit 1 ;;
        esac
        ;;
    recommend)      recommend_fit ;;
    mmproj)         manage_mmproj "$@" ;;
    auto)
        # serve auto [main|aux] [--vision] [--free] [--ui ...]
        # Forward everything to serve_auto which parses its own flags
        serve_auto "$@"
        ;;
    downscale)      serve_downscale ;;
    main)           serve_main "${1:-}" ;;
    aux)            serve_aux "${1:-}" ;;
    herm)           serve_herm "$@" ;;
    api)
        shift
        case "${1:-list}" in
            list) nvidia_nim_list ;;
            use)  shift; nvidia_nim_use "${1:-}" "${2:-main}" ;;
            *)    echo "Usage: serve api {list|use <rank|api_id> [main|aux]}"; exit 1 ;;
        esac
        ;;
    daemon)
        # $1 is the daemon subcommand (install/remove/etc) — already shifted past 'daemon'
        daemon_cmd="${1:-list}"
        shift || true
        case "${daemon_cmd}" in
            install)  daemon_install "$@" ;;
            remove)   daemon_remove "$@" ;;
            start)    daemon_start "$@" ;;
            stop)     daemon_stop "$@" ;;
            restart)  daemon_restart "$@" ;;
            status)   daemon_status "$@" ;;
            list)     daemon_list ;;
            migrate)  daemon_migrate "$@" ;;
            *)        echo "Usage: serve daemon {install|remove|start|stop|restart|status|list|migrate}"; exit 1 ;;
        esac
        ;;
    help|*)
        if alias_exists "${cmd}" 2>/dev/null; then
            launch_server "${cmd}"
        else
            usage
        fi
        ;;
esac